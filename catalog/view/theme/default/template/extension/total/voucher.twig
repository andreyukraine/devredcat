<div class="panel panel-default">
  <div class="panel-heading">
    <div class="panel-title-discont">
      <a href="#collapse-voucher" data-toggle="collapse" data-parent="#accordion" class="accordion-toggle">
        {{ heading_title }} <i class="fa fa-caret-down"></i>
      </a>
    </div>
  </div>
  <div id="collapse-voucher" class="block-voucher collapse">
    <div class="block-voucher-line">
      <div class="t-voucher">
        <input type="text" name="voucher" value="{{ voucher }}" placeholder="{{ entry_voucher }}" id="input-voucher"
               class="form-control"/>
      </div>
      <div class="input-group text-right">
        <span class="input-group-btn">
          <input type="submit" value="{{ button_voucher }}" id="button-voucher" data-loading-text="{{ text_loading }}"
                 class="btn btn-primary"/>
        </span>
      </div>
    </div>
  </div>
</div>

