<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {% for breadcrumb in breadcrumbs %}
  {% if not loop.first %}
        {
          "@type": "ListItem",
          "position": {{ loop.index -1 }},
          "item": {
            "@id": "{{ breadcrumb.href }}",
            "name": "{{ breadcrumb.text }}"
          }
        }{% if not loop.last %},{% endif %}
  {% endif %}
  {% endfor %}
  ]
}
</script>
