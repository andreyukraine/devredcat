<script type="application/ld+json">
    {
      "@context": "https://schema.org/",
      "@type": "WebSite",
      "name": "{{ name }}",
      "url": "{{ url }}",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "{{ url }}search/?search={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
</script>
<script type="application/ld+json">
  { "@context" : "https://schema.org",
    "@type" : "Organization",
    "url" : "{{ url }}",
    "contactPoint" : [
      { "@type" : "ContactPoint",
        "telephone" : "{{ telephone }}",
        "contactType" : "customer service"
      } ] }
</script>

