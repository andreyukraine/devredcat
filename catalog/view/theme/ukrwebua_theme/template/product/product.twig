<script src="/catalog/view/javascript/jquery/magnific/jquery.magnific-popup.min.js"></script>
<link href="/catalog/view/javascript/jquery/magnific/magnific-popup.css" rel="stylesheet" type="text/css"/>

<script type="text/javascript">

  var product_id = '{{ product_id }}';
  var contextSelector = '#product-product #product-' + product_id;

  $(document).ready(function () {

    var mainSlider = $(contextSelector + " .slider-for-" + product_id);

    mainSlider.css('opacity', 0);

    mainSlider.on('init', function (slick) {
      mainSlider.css('opacity', 1);
    });

    var initialSlideIndex = 0; // значення за замовчуванням
    var $activeSlide = $(contextSelector + " .slider-for-" + product_id + " .select");
    if ($activeSlide.length) {
      initialSlideIndex = $activeSlide.data('pos') || 0;
    }

    var is_mobile = '{{ is_mobile }}' == '1';

    mainSlider.not('.slick-initialized').slick({
      slidesToShow: 1,
      slidesToScroll: 1,
      speed: 500,
      arrows: true,
      dots: is_mobile,
      fade: true,
      centerMode: true,
      asNavFor: contextSelector + " .slider-nav-" + product_id,
      initialSlide: initialSlideIndex, // встановлюємо початковий слайд
      prevArrow: '<button type="button" class="slick-prev slick_arrow"><i class="slick-arrow-left"></i></button>',
      nextArrow: '<button type="button" class="slick-next slick_arrow"><i class="slick-arrow-right"></i></button>'
    });

    mainSlider.on('afterChange', function(event, slick, currentSlide) {
      var $slide = $(slick.$slides[currentSlide]);
      var className = $slide.attr('class');
      var match = className.match(/product-image-options-([0-9-]+)/);

      if (match && match[1]) {
        var optionValue = match[1];
        var $input = $('input[name="option[' + product_id + ']"][value="' + optionValue + '"]');
        if ($input.length && !$input.prop('checked')) {
          $input.closest('.options-box').first().trigger('click');
          $input.first().trigger('click');
        }
      }
    });

    var mainNavSlider = $(contextSelector + " .slider-nav-" + product_id);

    mainNavSlider.css('opacity', 0);

    mainNavSlider.on('init', function (slick) {
      mainNavSlider.css('opacity', 1);
    });

    mainNavSlider.not('.slick-initialized').slick({
      slidesToShow: 3,
      slidesToScroll: 1,
      speed: 500,
      asNavFor: contextSelector + " .slider-for-" + product_id,
      arrows: true,
      dots: false,
      centerMode: false,
      focusOnSelect: true,
      // slide: "div",
      initialSlide: initialSlideIndex, // встановлюємо початковий слайд
      prevArrow: '<button type="button" class="slick-prev slick_arrow"><i class="slick-arrow-left"></i></button>',
      nextArrow: '<button type="button" class="slick-next slick_arrow"><i class="slick-arrow-right"></i></button>'
    });

    $(contextSelector + ' .slider-for-' + product_id).magnificPopup({
      type: 'image',
      delegate: 'a.main-image-popup',
      gallery: {
        enabled: true
      }
    });

    // Функція для завантаження відгуків
    function loadReviews(page) {
      $('#review').load('index.php?route=product/product/review&product_id={{ product_id }}&page=' + page);
    }

    // Початкове завантаження відгуків
    loadReviews(1);

    // Обробка кліків по пагінації
    $(document).on('click', '#review .bl-pagination a', function (e) {
      e.preventDefault();
      var href = $(this).attr('href');

      // Якщо параметр page відсутній, це перша сторінка (page=1)
      var page = 1;
      var pageMatch = href.match(/page=(\d+)/);
      if (pageMatch) {
        page = pageMatch[1];
      }

      loadReviews(page);
    });

  });

</script>


