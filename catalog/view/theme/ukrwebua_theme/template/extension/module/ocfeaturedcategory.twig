<div class="featured-categories-container" id="featured_module{{ module_id }}">
  <div class="featured-categories-slider module-title">
    <h2 class="bl-bold">{{ heading_title }}</h2>
  </div>

  {% set count, rows = 0, config_slide.f_rows %}
  {% if not rows %}
    {% set rows = 1 %}
  {% endif %}
  <div class="featured-categories-content">
    <div class="slick-container">
      <div class="slick-featured-categories">
        {% for category in categories %}
          {% if count % rows == 0 %}
            <div class="row_items">
          {% endif %}
          {% set count = count + 1 %}
          <div class="item">
            <div class="item-inner">
              <div class="fcategory-content">
                <a href="{{ category.href }}">
                  <div class="c-img" style="background-color: {{ category.color }}">
                    <div class="category-image" style="background-image: url('{{ category.homethumb_image }}')"></div>
                  </div>
                  <div class="content-thumb">
                    <h3 class="name bl-bold">{{ category.name }}</h3>
                  </div>
                </a>
              </div>
            </div>
          </div>
          {% if (count % rows == 0) or (count == categories|length) %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% if config_slide.use_slider %}
  <style>
    .slick-featured-categories {
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    .slick-featured-categories.slick-initialized {
      opacity: 1;
    }
  </style>
  <script>
    $(document).ready(function () {
      var ocfeatured_categoryNavSlider = $("#featured_module{{ module_id }} .slick-featured-categories");

      // Функція для ініціалізації слайдера
      function initSlider() {
        var itemsToShow = getSlidesToShow();

        ocfeatured_categoryNavSlider.slick({
          slidesToShow: itemsToShow,
          slidesToScroll: itemsToShow,
          autoplay: false,
          autoplaySpeed: 3000,
          arrows: true,
          dots: false,
          pauseOnHover: false,
          onInit: function () {
            ocfeatured_categoryNavSlider.css('opacity', 1);
          }
        });
      }

      // Функція для визначення кількості слайдів
      function getSlidesToShow() {
        var windowWidth = $(window).width();
        if (windowWidth < 375) {
          return 1;
        } else if (windowWidth < 480) {
          return 1;
        } else if (windowWidth < 768) {
          return 2;
        } else if (windowWidth < 992) {
          return 3;
        } else if (windowWidth < 1200) {
          return 4;
        } else {
          return 5; // значення за замовчуванням
        }
      }

      // Ініціалізація слайдера
      initSlider();

      // Респонсив поведінка
      $(window).on('resize', function () {
        var currentSlidesToShow = ocfeatured_categoryNavSlider.slick('slickGetOption', 'slidesToShow');
        var newSlidesToShow = getSlidesToShow();

        if (currentSlidesToShow !== newSlidesToShow) {
          ocfeatured_categoryNavSlider.slick('unslick');
          initSlider();
        }
      });
    });
  </script>
{% endif %}
