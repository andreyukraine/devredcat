
<div class="bl-comment">
  <span class="bl-bold">
    <a href="#comment-ord" data-toggle="collapse" title="Додати коментар до замовлення" data-parent="#accordion" class="accordion-toggle collapsed" aria-expanded="false">
      Додати коментар до замовлення
    </a>
  </span>

  <div id="comment-ord" class="collapse" aria-expanded="false">
    <div class="form-group">
      <label class="control-label" for="input-comment">{{ entry_comment }}</label>
      <textarea name="comment" rows="5" placeholder="{{ entry_comment }}" id="input-comment" class="form-control">{{ comment }}</textarea>
    </div>
  </div>
</div>
