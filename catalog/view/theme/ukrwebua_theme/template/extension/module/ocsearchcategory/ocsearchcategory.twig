<div id="search-by-category" class="input-group">
  <div class="btn-group">
    <div class="dropdown-menu search-content">
      <div class="container">
        <div class="inner">
          <div class="search-container">
            <div class="search-title">
              <div class="text-21 bl-bold">{{ text_search }}</div>
              <div class="button-close"><img alt="close" width="25" height="25px" src="/image/close.svg"></div>
            </div>
            <div class="input-wrapper">
              <input type="text" id="text-search" placeholder="Почніть вводити (мінімум 3 символи)...">
            </div>
          </div>
          <div class="search-ajax">
            <div class="ajax-loader-search" style="display: none;">
              <img alt="loading" src="{{ ocsearchcategory_loader_img }}" class="ajax-load-img" width="30" height="30"/>
            </div>
            <div class="ajax-result-search">
              <!-- Content of search results -->
            </div>
          </div>
          <input type="hidden" id="ajax-search-enable" value="1"/>
        </div>
      </div>
    </div>
  </div>

</div>

<script>
  $(document).ready(function () {

    $(document).on('click', '.dropdown-toggle.search-button', function(e) {
      e.preventDefault();
      ocmenuview_top.hide();
    });

    // Автоматичний фокус на поле введення при відкритті пошуку
    $('#search-by-category .btn-group').on('shown.bs.dropdown', function () {
      $('#text-search').focus();
    });

    var flag = true;
    var current_cate_value = $('ul.cate-items li.selected').data('value');
    var current_cate_text = $('ul.cate-items li.selected').html();
    var searchTimeout; // Таймер для debounce
    var minSearchLength = 3; // Мінімальна кількість символів для пошуку

    $('.cate-selected').attr('data-value', current_cate_value);
    $('.cate-selected').html(current_cate_text);

    $('.hover-cate p').click(function () {
      $(".cate-items").toggle("slow");
    });

    $('.ajax-result-search').hover(
      function () {
        flag = true;
      },
      function () {
        flag = false;
      }
    );


    $('#text-search').keyup(function (e) {
      // Очищаємо попередній таймер, якщо він був
      clearTimeout(searchTimeout);

      var text_search = $(this).val();
      var cate_search = $('.cate-selected').attr("data-value");

      // Встановлюємо новий таймер на 300 мс, але тільки якщо достатньо символів
      if (text_search && text_search.length >= minSearchLength) {
        $('.search-ajax').show();
        searchTimeout = setTimeout(function() {
          ajaxSearch(text_search, cate_search);
        }, 400);
      } else {
        // Якщо символів менше мінімальної кількості - приховуємо результати
        $('.ajax-result-search').html('');
        $('.ajax-loader-search').hide();
      }
    });

    $('ul.cate-items li.item-cate').click(function () {
      var cate_search = $(this).data('value');
      var text_search = $('#text-search').val();
      $('.cate-selected').attr('data-value', cate_search);
      $('.cate-selected').html($(this).html());
      if (text_search && text_search.length >= minSearchLength) {
        ajaxSearch(text_search, cate_search);
      } else {
        $('.ajax-result-search').html('');
        $('.ajax-loader-search').hide();
      }
      $(".cate-items").hide();
      $('#text-search').focus();
    });

    function ajaxSearch(text_search, cate_search) {
      // Скасовуємо попередній запит, якщо він ще не завершився
      if (typeof ajaxSearch.xhr !== 'undefined') {
        ajaxSearch.xhr.abort();
      }

      ajaxSearch.xhr = $.ajax({
        url: '{{ search_ajax_action }}',
        type: 'post',
        data: {text_search: text_search, cate_search: cate_search, ajax: "ajax_search"},
        beforeSend: function () {
          $('.search-container').addClass('custom_lock');
          $('.ajax-loader-search').show();
        },
        complete: function () {
          $('.search-container').removeClass('custom_lock');
        },
        success: function (json) {
          if (json['success'] == true) {
            flag = true;
            $('.search-ajax').show();
            $('.ajax-result-search').html(json['result_html']);
            $('.ajax-loader-search').hide();
          }
        }
      });
    }
  });

  function showSearchMore() {
    var url = '{{ search_action }}';
    var text_search = $('#text-search').val();
    if (text_search) {
      url += '&q=' + encodeURIComponent(text_search);
    }
    location.href = url; // Перехід на сторінку пошуку
  }

</script>
