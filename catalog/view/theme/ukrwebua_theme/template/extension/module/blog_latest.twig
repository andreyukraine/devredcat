<div class="bloglatest-container" id="bloglatest_module{{ module_id }}">
  <div class="bloglatest-slider module-title">
    <h2 class="bl-bold">{{ heading_title }}</h2>
  </div>
  {% set count, rows = 1, config_slide.f_rows %}
  {% if not rows %}
    {% set rows = 1 %}
  {% endif %}
  <div class="bloglatest-content">
    <div class="slick-container">
      <div class="slick-bloglatest">
        {% for article in articles %}
          {% if count % rows == 0 %}
            <div class="row_items">
          {% endif %}
          {% set count = count + 1 %}
          <div class="item">
            <div class="item-inner">
              <div class="article-content">
                <a title="{{ article.name }}" href="{{ article.href }}">
                  <div class="bl-article-img">
                    <div class="img-article" style="background-image: url('{{ article.thumb }}')"></div>
                  </div>
                  <div class="bl-article-title">
                    <div class="article-date">{{ article.date_added }}</div>
                    <div class="name text-18 bl-bold">{{ article.name }}</div>
                  </div>
                </a>
              </div>
            </div>
          </div>
          {% if (count % rows == 0) or (count == articles|length) %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<style>
  .slick-bloglatest {
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .slick-bloglatest.slick-initialized {
    opacity: 1;
  }
</style>
<script>
  $(document).ready(function () {
    var blog_latestNavSlider = $("#bloglatest_module{{ module_id }} .slick-bloglatest");

    // Функція для ініціалізації слайдера
    function initSlider() {
      var itemsToShow = getSlidesToShow();

      blog_latestNavSlider.slick({
        slidesToShow: itemsToShow,
        slidesToScroll: itemsToShow,
        autoplay: false,
        arrows: true,
        dots: false,
        pauseOnHover: false,
        onInit: function () {
          blog_latestNavSlider.css('opacity', 1);
        }
      });

      // Перевірка кількості елементів
      var totalItems = blog_latestNavSlider.find('.item').length;
      if (totalItems <= itemsToShow) {
        $('#bloglatest_module{{ module_id }} .navigation-slick-block').hide();
      } else {
        $('#bloglatest_module{{ module_id }} .navigation-slick-block').show();
      }
    }

    // Функція для визначення кількості слайдів
    function getSlidesToShow() {
      var windowWidth = $(window).width();
      if (windowWidth < 375) return 1;
      if (windowWidth < 480) return 1;
      if (windowWidth < 768) return 3;
      if (windowWidth < 992) return 3;
      if (windowWidth < 1200) return 3;
      return 3;
    }

    // Ініціалізація слайдера
    initSlider();

    // Обробники кнопок
    $('#bloglatest_module{{ module_id }} .slick-arrow-left').on('click', function () {
      blog_latestNavSlider.slick('slickPrev');
    });

    $('#bloglatest_module{{ module_id }} .slick-arrow-right').on('click', function () {
      blog_latestNavSlider.slick('slickNext');
    });

    // Респонсив поведінка
    $(window).on('resize', function () {
      var currentSlidesToShow = blog_latestNavSlider.slick('slickGetOption', 'slidesToShow');
      var newSlidesToShow = getSlidesToShow();

      if (currentSlidesToShow !== newSlidesToShow) {
        blog_latestNavSlider.slick('unslick');
        initSlider();
      }
    });
  });
</script>
