  //   }
  //
  //   if ($(this).attr('data-sort') < -$('#account .form-group').length) {
  //     $('#account .form-group:first').before(this);
  //   }
  // });

  $('#address .form-group[data-sort]').detach().each(function () {
    if ($(this).attr('data-sort') >= 0 && $(this).attr('data-sort') <= $('#address .form-group').length) {
      $('#address .form-group').eq($(this).attr('data-sort')).before(this);
    }

    if ($(this).attr('data-sort') > $('#address .form-group').length) {
      $('#address .form-group:last').after(this);
    }

    if ($(this).attr('data-sort') < -$('#address .form-group').length) {
      $('#address .form-group:first').before(this);
    }
  });

  //--></script>
<script><!--
  $('#ajax-register-form button[id^=\'button-custom-field\']').on('click', function (e) {
    e.preventDefault();
    var element = this;

    $('#form-upload-temp').remove();
    $('body').prepend('<form enctype="multipart/form-data" id="form-upload-temp" style="display: none;"><input type="file" name="file" /></form>');

    var $input = $('#form-upload-temp input[name=\'file\']');

    $input.on('change', function () {
      if (this.value != '') {
        var formData = new FormData($('#form-upload-temp')[0]);

        $.ajax({
          url: 'index.php?route=tool/upload',
          type: 'post',
          dataType: 'json',
          data: formData,
          cache: false,
          contentType: false,
          processData: false,
          beforeSend: function () {
            $(element).button('loading');
          },
          complete: function () {
            $(element).button('reset');
          },
          success: function (json) {
            $(element).parent().find('.text-danger, .text-success-file').remove();

            if (json['error']) {
              $(element).after('<div class="text-danger">' + json['error'] + '</div>');
            }

            if (json['success']) {
              $(element).parent().find('input[type="hidden"]').val(json['code']);
              $(element).after('<div class="text-success-file" style="color: #4caf50; font-weight: bold; margin-top: 5px;">Завантажено: ' + json['filename'] + '</div>');
            }
          },
          error: function (xhr, ajaxOptions, thrownError) {
            alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
          }
        });
      }
    });

    $input.trigger('click');
  });

  $("#input-telephone").mask("+38(999)999-99-99");

  //--></script>
