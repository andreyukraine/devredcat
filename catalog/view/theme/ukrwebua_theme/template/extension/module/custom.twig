{{ header }}
<div class="fluid-width">
  <div class="fluid-width">
    <div class="breadcrumbs container">
      <h1 class="category-name">{{ checkout_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div id="checkout-checkout" class="container">
    <script>
      // Перевірка на випадок натискання кнопки "Назад" у браузері
      window.onpageshow = function (event) {
        if (event.persisted || (window.performance && window.performance.navigation.type === 2)) {
          window.location.reload();
        }
      };
    </script>
    {% if errors %}
      {% for error in errors %}
        <div class="alert alert-warning">{{ error }}
          <button type="button" class="close" data-dismiss="alert">&times;</button>
        </div>
      {% endfor %}
    {% endif %}

    <div class="bl-content">
      {% if show_login_popup %}
        <script>
          if (typeof window.loginPopupTriggered === 'undefined') {
            window.loginPopupTriggered = false;
          }
          window.addEventListener('load', function () {
            setTimeout(function () {
              if (!window.loginPopupTriggered && typeof ocajaxlogin !== 'undefined' && typeof ocajaxlogin.appendLoginForm === 'function') {
                window.loginPopupTriggered = true;
                ocajaxlogin.appendLoginForm('{{ url_link_extension_module_custom }}');
              }
            }, 300);
          });
        </script>
      {% endif %}
      <div class="row">
        {% if not empty %}
          <div class="col-sm-7 checkout-data bl-stick">

            {% if logged %}
              <div id="custom-customer">
                {{ customer }}
              </div>
              {% if buy_org %}
                {% if shipping and shipping != constant('false') %}
                  <div id="custom-shipping-0">{{ shipping }}</div>
                {% endif %}
                {% if payment %}
                  <div id="custom-payment-0">{{ payment }}</div>
                {% endif %}
              {% else %}
                {% if split_order_store %}
                  {{ orders }}
                {% elseif order_by_store %}
                  {{ orders_by_store }}
                {% else %}
                  {% if shipping and shipping != constant('false') %}
                    <div id="custom-shipping-0">{{ shipping }}</div>
                  {% endif %}
                  {% if payment %}
                    <div id="custom-payment-0">{{ payment }}</div>
                  {% endif %}
                {% endif %}
              {% endif %}
            {% else %}
              <div class="bl-login-checkout">
                <div class="menu-top-login-icon"><img width="{{ user_logo_width }}" height="{{ user_logo_height }}"
                                                      src="/image/user-reg.svg"/></div>
                <div class="bl-menu-top-login-actions">
                  <div class="menu-top-login-actions">
                    <span class="menu-top-login-action-login bl-bold"
                          onclick="ocajaxlogin.appendLoginForm();">Увійти</span>
                    <span class="bl-bold" onclick="ocajaxlogin.appendTypeClientForm();">Реєстрація</span>
                  </div>
                  <div class="hidden-xs">Для оформлення замовлення, будь ласка, авторизуйтесь.</div>
                </div>
              </div>

            {% endif %}
          </div>
          <div class="col-sm-5 bl-stick">

            {% if buy_org %}
              {{ orders_org }}
            {% else %}
              <div class="text-21 bl-bold">Список товарів</div>
              {% if split_order_store != true or orders_by_store != true %}
                <div id="custom-cart">
                  {{ cart }}
                </div>
              {% endif %}
            {% endif %}

            {#          {% if module %} #}
            {#            <div id="custom-module">{{ module }}</div> #}
            {#          {% endif %} #}

            {% if total %}
              <hr>
              <div id="custom-total">
                {{ total }}
              </div>
            {% endif %}

            {% if comment and comment != constant('false') %}
              <div id="custom-comment-0">{{ comment }}</div>
            {% endif %}

            {% if logged %}
            <div id="custom-button">
              {{ button }}
            </div>
            {% endif %}

          </div>
        {% else %}
          <div class="col-sm-12">
            <p class="text-center">
              <svg class="icon-empty-cart" id="icon-empty-shop-cart" xmlns="http://www.w3.org/2000/svg" width="195"
                   height="151" fill="none" viewBox="0 0 195 151">
                <path fill="#9CA9BC"
                      d="m170.452 109.713 1.98.273-1.49 10.798-1.982-.274 1.492-10.797ZM38 45h2v32h-2V45Zm0 39h2v9h-2v-9Zm107.8 42.7c.2.3.5.4.8.4.2 0 .4-.1.6-.2 1.5-1 3.6-1.1 5.2-.1.5.3 1.1.2 1.4-.3.3-.5.2-1.1-.3-1.4-2.2-1.4-5.2-1.4-7.4.1-.5.4-.6 1-.3 1.5ZM70 113h9v2h-9v-2ZM5 144h13v2H5v-2Z"></path>
                <path fill="#9CA9BC"
                      d="m173 144 .3-.9 5-39.1h.7c2.2 0 4-1.4 4-3.2v-1.5c0-1.8-1.8-3.2-4-3.2h-34.7l9.1-22c.8-2-.1-4.4-2.2-5.2-1-.4-2.1-.4-3.1 0s-1.8 1.2-2.2 2.2L136.5 94c-1.2.4-2.1 1.1-2.9 2H132V37c0-3.3-2.7-6-5.9-6-6.3 0-12.6-.7-18.9-.9-4-14.7-14-25.1-25.7-25.1S59.8 15.4 55.8 30c-6.4.2-12.7.5-18.8 1-3.3 0-6 2.7-6 6v75.9L27.1 144H23v2h167v-2h-17Zm-1.7-1.2c-.1.9-.9 1.2-1.6 1.2h-33.8l-3.9-31.1V104h2.2c1.1 1 2.3 1.7 3.9 1.7s2.9-.6 3.9-1.7h34.3l-5 38.8Zm9.7-43.6v1.5c0 .6-.8 1.2-2 1.2h-35.1c.3-.7.5-1.5.5-2.3 0-.6-.1-1.1-.2-1.7H179c1.2.1 2 .8 2 1.3Zm-33.2-27.5c.2-.5.6-.9 1.1-1.1.5-.2 1-.2 1.5 0 1 .4 1.5 1.6 1.1 2.6l-9.1 22c-1.1-1-2.4-1.5-3.6-1.7l9-21.8Zm-9.5 24c2.2 0 4 1.8 4 4s-1.8 4-4 4-4-1.8-4-4 1.8-4 4-4Zm-5.7 2.3c-.2.5-.2 1.1-.2 1.7 0 .8.2 1.6.5 2.3h-.9v-4h.6ZM81.5 7c10.7 0 19.8 9.5 23.6 23-16.1-.5-31.9-.5-47.2 0 3.8-13.5 13-23 23.6-23ZM32.8 115H59v-2H33V37c0-2.2 1.8-4 4.1-4 6-.4 12.1-.7 18.3-.9-.5 2.3-.9 4.7-1.1 7.2-2.3.4-4.1 2.4-4.1 4.8 0 2.7 2.2 4.9 4.9 4.9s4.9-2.2 4.9-4.9c0-2.3-1.6-4.1-3.6-4.7.2-2.5.6-5 1.2-7.3 15.6-.5 31.7-.5 48.2.1.6 2.3.9 4.8 1.2 7.3-2.1.5-3.6 2.4-3.6 4.7 0 2.7 2.2 4.9 4.9 4.9s4.9-2.2 4.9-4.9c0-2.4-1.8-4.4-4.1-4.8-.2-2.4-.6-4.8-1.1-7.1 6.1.2 12.2.5 18.3.9 2.2 0 4 1.8 4 4v76H89v2h41.2l3.6 29H29.1l3.7-29.2Zm23.3-73.6c1 .4 1.8 1.5 1.8 2.6 0 1.6-1.3 2.9-2.9 2.9-1.6 0-2.9-1.3-2.9-2.9 0-1.3.8-2.3 1.9-2.7 0 .9-.1 1.8-.1 2.7h2c.1-.9.1-1.8.2-2.6ZM107 44h2c0-.9 0-1.8-.1-2.7 1.1.4 1.9 1.4 1.9 2.7 0 1.6-1.3 2.9-2.9 2.9-1.6 0-2.9-1.3-2.9-2.9 0-1.2.7-2.2 1.8-2.6.2.8.2 1.7.2 2.6Z"></path>
                <path fill="#9CA9BC"
                      d="M145.6 120.2a2 2 0 1 0 .001-3.999 2 2 0 0 0-.001 3.999Zm8 0a2 2 0 1 0 .001-3.999 2 2 0 0 0-.001 3.999Zm-67-40.9c-2.8-1.8-6.7-1.8-9.4.2-.5.3-.6.9-.3 1.4.2.3.5.4.8.4.2 0 .4-.1.6-.2 2.1-1.5 5.1-1.5 7.2-.1.5.3 1.1.2 1.4-.3.3-.5.1-1.1-.3-1.4Zm-12.9-5.9a2.7 2.7 0 1 0 0-5.4 2.7 2.7 0 0 0 0 5.4Zm16 0a2.7 2.7 0 1 0 0-5.4 2.7 2.7 0 0 0 0 5.4Z"></path>
              </svg>
            </p>
            <p class="text-21 bl-bold text-center">{{ cart_is_empty }}</p>
            <p class="cart-empty-info-text text-center">{{ text_empty_marketing }}</p>
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  <div id="checkout-confirm" style="display: none;">
    <div id="checkout-checkout" class="container">
      <div id="custom-confirm"></div>
    </div>
  </div>

  <!-- Modal for Nova Poshta Map -->
  <div class="modal fade" id="modal-np-map" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <h3 class="modal-title text-21 bl-bold">Мапа</h3>
          <img width="25px" height="25px" src="/image/close.svg" class="close" data-dismiss="modal" aria-label="Close" alt="close">
        </div>
        <div class="modal-body" style="padding: 0 !important; position: relative;">
          <div id="np-map-container" style="height: 600px; width: 100%;"></div>
          <div id="np-map-loading" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.7); display: flex; align-items: center; justify-content: center; z-index: 10;">
            <div><i class="fa fa-spinner fa-spin fa-2x"></i> Завантаження відділень...</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>

    function handleCreateOrderClick() {

      $('#checkout-checkout').addClass('custom_lock');

      custom_block.checkoutCustomer()
      {% if not logged %}
        {% if login is defined and login != constant('false') %}
        .then(custom_block.checkoutLogin)
        {% endif %}
      {% endif %}
        .then(custom_block.checkoutShipping)
        .then(custom_block.checkoutPayment)
        .then(custom_block.checkoutComment)
        .then(custom_block.checkoutRemaning)
        .then(custom_block.checkoutConfirm)
        .catch(custom_block.failureCallback);

    }

  </script>
</div>
{{ footer }}
