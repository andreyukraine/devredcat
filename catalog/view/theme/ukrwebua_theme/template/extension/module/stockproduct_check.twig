<div class="modal-dialog modal-dialog-centered">
  <div class="modal-content">
    <div id="popup-check-store">
    <div class="modal-header">
      <button type="button" class="close" data-dismiss="modal">&times;</button>
      <div class="modal-title h4">Виберіть з якого магазину відвантажити:</div>
    </div>
    <div class="modal-body">
      <div class="bl-stock-warehouses">
        <div class="title-stock-warehouses">{{ title_stock_warehouses }}</div>
        {% for warehouse in warehouses %}
          <div class="stock_item">
            <div class="l-store-radio">
              <input type="radio" id="{{ warehouse.warehouse_id }}" value="{{ warehouse.warehouse_id }}"><span>{{ warehouse.name }}</span>
            </div>
            <span>{{ warehouse.quantity }}</span>
          </div>
        {% endfor %}
      </div>
    </div>
    </div>
  </div>
</div>
