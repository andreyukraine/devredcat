{{ header }}
<div class="fluid-width">
  <div id="account-login" class="container">
    <div class="top-cat">
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
    <div class="bl-content">
      <div id="content" class="bl-registration-type">
        <div class="row">
          <div class="bl-welcome-text col-sm-6">
              <h1 class="bl-bold">Ласкаво просимо</h1>
              <div class="bl-welcome-text-desc">
                <p class="text">Дякуємо, що обрали нашу компанію. Ми маємо можливість формувати різні спеціальні, оптові та персональні знижки та бонуси для різних типів наших клієнтів</p>
                <p class="text">Будь ласка, завершіть вашу реєстрацію, обравши тип акаунту та доповніть реєстраційні дані</p>
              </div>
          </div>
          <div class="col-sm-6">
            <p class="login-section-select-type-text bl-bold">Виберіть тип облікового запису</p>
            <form action="{{ register }}" method="post" id="account-type-form">
                <div class="login-section-select-type">
                  <div class="bl-item-radio-reg">
                    <input id="client" type="radio" name="customer_type" class="custom-control-input" value="{{ type_default }}" required>
                    <label class="custom-control-label" for="client">
                      <div class="line-type-reg">
                        <div class="login-section-select-type-item-icon"><img src="/image/client_reg.svg" alt=""></div>
                        <div class="bl-item-type-name"><p class="login-section-select-type-item-title">Я - власник тварини</p>
                          <p class="login-section-select-type-item-text">Проста реєстрація для роздрібних покупців</p></div>
                      </div>
                    </label>
                  </div>
                  <div class="bl-item-radio-reg">
                    <input id="wholesaler" type="radio" name="customer_type" class="custom-control-input" value="{{ type_store }}">
                    <label class="custom-control-label" for="wholesaler">
                      <div class="line-type-reg">
                        <div class="login-section-select-type-item-icon"><img src="/image/wholesaler_reg.svg" alt=""></div>
                        <div class="bl-item-type-name"><p class="login-section-select-type-item-title">Оптовий покупець</p>
                          <p class="login-section-select-type-item-text">Зоомагазини та інтернет-магазини</p></div>
                      </div>
                    </label>
                  </div>
                  <div class="bl-item-radio-reg">
                    <input id="nursery" type="radio" name="customer_type" class="custom-control-input" value="{{ type_breeder }}">
                    <label class="custom-control-label" for="nursery">
                      <div class="line-type-reg">
                        <div class="login-section-select-type-item-icon"><img src="/image/nursery_reg.svg" alt=""></div>
                        <div class="bl-item-type-name"><p class="login-section-select-type-item-title">Розплідник</p>
                          <p class="login-section-select-type-item-text">Заводчики тварин та розплідники</p></div>
                      </div>
                    </label>
                  </div>
                </div>

              <div class="buttons">
                <div class="dflex-row-justify-between">
                  <div class="pull-left d-flex">
                    <a href="{{ back }}" title="Повернутись"><img class="btn-back" alt="Повернутись" src="/image/back.svg"></a>
                    <a href="{{ back }}" title="Повернутись" class="bl-bold text-18 hidden-xs"><span>Повернутись</span></a>
                  </div>
                  <div class="pull-right">
                    <input type="submit" value="{{ button_continue }}" class="button"/>
                  </div>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{{ footer }}
