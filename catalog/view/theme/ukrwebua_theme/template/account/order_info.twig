{{ header }}
<div class="fluid-width">
  <div id="account-order" class="container layer-category">
    <div class="row">
      <div class="col-sm-3">
        {{ menu }}
      </div>
      <div class="bl-account col-sm-9">

        <span class="text-21 bl-bold">{{ text_order_detail }}</span>

        <div class="order-status">{{ status }}</div>
        {% if success %}
          <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
            <button type="button" class="close" data-dismiss="alert">&times;</button>
          </div>
        {% endif %}
        {% if error_warning %}
          <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
            <button type="button" class="close" data-dismiss="alert">&times;</button>
          </div>
        {% endif %}
        <div class="order-inf">
          <div class="{{ class }}">
            <table class="table table-hover">
              <thead>

              </thead>
              <tbody>
              <tr>
                <td class="text-left" style="width: 50%;">
                  <b>{{ text_date_added }}</b> {{ date_added }}<br/>
                  {% if invoice_no %} <b>{{ text_invoice_no }}</b> {{ invoice_no }}<br/>{% endif %}
                  <b>{{ text_order_id }}</b> #{{ order_id }}
                </td>
                <td class="text-left" style="width: 50%;">
                  <div class="bl-pay-shipment">
                    <div class="block-payment">
                      {% if payment_method %} <b>{{ text_payment_method }}</b>
                        {{ payment_method }}<br/>

                        {% if order_status == 1 %}
                          {{ action_pay }}
                        {% endif %}
                      {% endif %}
                    </div>
                    <div class="block-shipping">
                      {% if shipping_method %} <b>{{ text_shipping_method }}</b>
                        {{ shipping_method }}<br/>

                        {{ shipping_address }}<br/>

                      {% endif %}
                    </div>
                  </div>
                </td>
              </tr>
              </tbody>
            </table>
            <br>
            <h3 class="bl-bold">Список товарів</h3>
            <div class="table-responsive">
              <table class="table table-bordered table-prod-order">
                <thead>
                <tr>
                  <td class="text-left" style="width: 50%">{{ column_name }}</td>
                  <td class="text-right">Замовлено (к-ть)</td>
                  <td class="text-right">Наявна (к-ть)</td>
                  <td class="text-right">{{ column_price }}</td>
                  <td class="text-right">Знижка</td>
                  <td class="text-right">{{ column_total }}</td>
                </tr>
                </thead>
                <tbody>

                {% for product in products %}
                  <tr>
                    <td class="text-left" style="width: 50%">
                      {{ product.name }}
                      {% for option in product.option %} <br/>
                        &nbsp;<small> - {{ option.name }}: {{ option.value }}</small> {% endfor %}
                      {#              <a href="{{ product.return }}" data-toggle="tooltip" title="{{ button_return }}"><i class="fa fa-reply"></i></a> #}
                    </td>

                    <td class="text-right">{{ product.quantity_order }}</td>
                    <td class="text-right">{{ product.quantity }}</td>
                    <td class="text-right">{{ product.price }}</td>
                    <td class="text-right">{{ product.percent }}%</td>
                    <td class="text-right">{{ product.total }}</td>
                  </tr>
                {% endfor %}</tbody>
              </table>
              <div class="table-responsive">
                <table class="table table-hover">
                    <tr>
                      <td class="text-right"><b>Загалом: </b>&nbsp;{{ sum_total_text }}</td>
                    </tr>
                </table>
              </div>
            </div>
            {% if comment %}
              <table class="table table-hover">
                <thead>
                <tr>
                  <td class="text-left">{{ text_comment }}</td>
                </tr>
                </thead>
                <tbody>
                <tr>
                  <td class="text-left">{{ comment }}</td>
                </tr>
                </tbody>
              </table>
            {% endif %}
            <br>
            <br>
            <div class="buttons clearfix">
                <div class="pull-left d-flex" style="cursor: pointer">
                  <a href="{{ back }}">
                    <img class="btn-back" alt="Повернутись" src="/image/back.svg">
                    <span class="bl-bold text-18 hidden-xs">Повернутись</span>
                  </a>
                </div>
                <div class="pull-left"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
{{ footer }}
