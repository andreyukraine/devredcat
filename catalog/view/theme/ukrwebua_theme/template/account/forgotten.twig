{{ header }}
<div class="fluid-width">
  <div id="account-login" class="container">
    <div class="top-cat">
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
    {% if success %}
      <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}</div>
    {% endif %}
    {% if error_warning %}
      <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      </div>
    {% endif %}
    <div class="bl-content bl-login-bg">
        <div class="d-flex row">
          <div class="col-lg-7 col-md-5 hidden-xs hidden-sm" style="background-image: url('{{ image }}'); background-repeat: no-repeat;background-size: cover;">
            <div class="account-bg"></div>
          </div>
          <div class="col-lg-5 col-md-7 col-xs-12">

            <a title="{{ text_login }}" href="{{ login }}" class="registration-link bl-bold text-18 hidden-xs">
              {{ text_login }}
              <span class="open-submenu"></span>
            </a>

            <div class="p-50">
              <h1 class="bl-bold">{{ text_forgotten }}</h1>
              <br>
              <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-forgotten">

                <div class="form-group">
                  <label class="control-label" for="input-email">{{ entry_email }}</label>
                  <input type="text" name="email" value="{{ email }}" placeholder="{{ entry_email }}" id="input-email"
                         class="form-control"/>
                  {% if error_email %}
                  <div class="for-error error-email text-danger">{{ error_email }}</div>
                  {% endif %}
                </div>

                {{ captcha }}

                <br><br>
                <div class="buttons clearfix">
                  <div class="pull-left d-flex">
                    <a href="{{ back }}" title="Повернутись"><img class="btn-back" alt="Повернутись" src="/image/back.svg"></a>
                    <a href="{{ back }}" title="Повернутись" class="bl-bold text-18 hidden-xs"><span>Повернутись</span></a>
                  </div>
                  <div class="pull-left"></div>
                  <div class="pull-right">
                    <input type="submit" value="{{ button_continue }}" class="button"/>
                  </div>
                </div>
              </form>
            </div>
          </div>
        </div>
    </div>
  </div>
</div>
{{ footer }}
