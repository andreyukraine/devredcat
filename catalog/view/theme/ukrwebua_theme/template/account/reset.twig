{{ header }}
<div class="fluid-width">
  <div id="account-login" class="container">
    <div class="top-cat">
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
    {% if success %}
      <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}</div>
    {% endif %}
    {% if error_warning %}
      <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      </div>
    {% endif %}
    <div class="bl-content bl-login-bg">
      {% if config_is_catalog > 0 %}
        <div class="d-flex">
          <div class="col-lg-7 col-md-7 hidden-xs hidden-sm"
               style="background-image: url('{{ image }}'); background-repeat: no-repeat; background-size: cover;">
            <div class="account-bg"></div>
          </div>
          <div class="col-lg-5 col-md-5 col-xs-12">
            <div class="p-50">
              <h1 class="bl-bold">{{ heading_title }}</h1>
              <br>
              <div class="is-catalog text-center">
                <img alt="no_image" src="/image/no_image.png" width="200">
                <div class="bl-is-catalog-info">
                  <p class="text-21 bl-bold">Наразі сайт функціонує у форматі каталогу.</p>
                  <p class="text-16" style="color: #777">Ми працюємо над запуском оформлення замовлення</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      {% else %}
        <div class="d-flex">
          <div class="col-lg-7 col-md-7 hidden-xs hidden-sm"
               style="background-image: url('{{ image }}'); background-repeat: no-repeat; background-size: cover;">
            <div class="account-bg"></div>
          </div>
          <div class="col-lg-5 col-md-5 col-xs-12">

            <div class="p-50">
              <h1 class="bl-bold">{{ text_password }}</h1>
              <br>
              <form action="{{ action }}" method="post" enctype="multipart/form-data" class="form-horizontal">
                <div class="form-group">
                  <label class="col-sm-3 control-label" for="input-password">{{ entry_password }}</label>
                  <div class="col-sm-9">
                    <input type="password" name="password" value="{{ password }}" id="input-password"
                           class="form-control"/>
                    {% if error_password %}
                      <div class="text-danger">{{ error_password }}</div>
                    {% endif %} </div>
                </div>
                <div class="form-group">
                  <label class="col-sm-3 control-label" for="input-confirm">{{ entry_confirm }}</label>
                  <div class="col-sm-9">
                    <input type="password" name="confirm" value="{{ confirm }}" id="input-confirm"
                           class="form-control"/>
                    {% if error_confirm %}
                      <div class="text-danger">{{ error_confirm }}</div>
                    {% endif %}</div>
                </div>
                <div class="dflex-row-justify-between">
                  <button type="submit" class="button">{{ button_continue }}</button>
                </div>
              </form>
            </div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>
{{ footer }}
