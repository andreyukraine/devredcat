                <path fill="#9CA9BC"
                      d="M145.6 120.2a2 2 0 1 0 .001-3.999 2 2 0 0 0-.001 3.999Zm8 0a2 2 0 1 0 .001-3.999 2 2 0 0 0-.001 3.999Zm-67-40.9c-2.8-1.8-6.7-1.8-9.4.2-.5.3-.6.9-.3 1.4.2.3.5.4.8.4.2 0 .4-.1.6-.2 2.1-1.5 5.1-1.5 7.2-.1.5.3 1.1.2 1.4-.3.3-.5.1-1.1-.3-1.4Zm-12.9-5.9a2.7 2.7 0 1 0 0-5.4 2.7 2.7 0 0 0 0 5.4Zm16 0a2.7 2.7 0 1 0 0-5.4 2.7 2.7 0 0 0 0 5.4Z"></path>
              </svg>
            </li>
            <li>
              <p class="text-21 bl-bold text-center">{{ text_empty }}</p>
              <p class="cart-empty-info-text text-center">{{ text_empty_marketing }}</p>
            </li>
          {% endif %}
        </div>
      {% endif %}
    {% endif %}
  </div>
  {% if config_is_catalog <= 0 %}
    {% if products or store %}
      <div class="cart-fix-total">
        <div class="cart-total-bl">
          <table class="table">
            {% for total in totals %}
              <tr>
                <td class="text-left cart-text-bottom text-18 bl-bold">{{ total.title ~ " :" }}</td>
                <td class="text-right cart-value-bottom text-18 bl-bold">{{ total.text }}</td>
              </tr>
            {% endfor %}
          </table>
        </div>
        <div class="text-center cart-button">
          {% if module_custom_fastorder %}
            <div class="button-fast-order visible-lg" onclick="custom_cart.fastorder()">{{ button_fastorder }}</div>
          {% endif %}
          {% if not logged %}
            <a class="button button-cart" title="{{ button_checkout }}" href="javascript:void(0);" onclick="ocajaxlogin.appendLoginForm('{{ checkout }}');">{{ button_checkout }}</a>
          {% else %}
            <a class="button button-cart" title="{{ button_checkout }}" href="{{ checkout }}">{{ button_checkout }}</a>
          {% endif %}
        </div>
      </div>
    {% endif %}
  {% endif %}
</div>

<div id="cartview-bg-block" onclick="custom_cart.close()">
  <!-- Quick View deep background -->
</div>

<div class="cartview-load-img">
  <img src="{{ ocquickview_loader_img }}" alt=""/>
