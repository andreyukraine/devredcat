{% if languages|length > 1 %}
  <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-language">

    <div class="bl-lang-select">
      {% for language in languages %}
        {% if language.code == code %}
            <span class="button btn-link btn-block language-select item-selected" type="button" name="{{ language.code }}">{{ language.code_view }}</span>
        {% else %}
            <span class="button btn-link btn-block language-select" type="button" name="{{ language.code }}">{{ language.code_view }}</span>
        {% endif %}
      {% endfor %}
    </div>

    <input type="hidden" name="code" value=""/>
    <input type="hidden" name="redirect" value="{{ redirect }}"/>
  </form>
{% endif %}
