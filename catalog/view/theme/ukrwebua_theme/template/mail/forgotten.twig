<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ text_greeting }}</title>
  <style>
    body {
      font-family: Arial, Helvetica, sans-serif;
      line-height: 1.6;
      color: #333;
      margin: 0;
      padding: 0;
      background: #fff;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
      background-image: url('{{ t_data.bg_url }}');
      background-position: top;
      background-size: cover;
      background-repeat: no-repeat;
    }
    .header {
      padding: 40px 40px 20px;
    }
    .header-table {
      width: 100%;
      border-collapse: collapse;
    }
    .logo-cell {
      width: 30%;
      vertical-align: top;
    }
    .info-cell {
      width: 70%;
      vertical-align: top;
      text-align: right;
      font-size: 11px;
      color: #333;
      line-height: 1.3;
    }
    .logo {
      max-width: 100px;
      height: auto;
    }
    .content {
      padding: 20px 40px 40px;
    }
    .reset-link {
      display: inline-block;
      padding: 12px 24px;
      background-color: #003f40;
      color: white !important;
      text-decoration: none;
      border-radius: 4px;
      margin: 20px 0;
      font-weight: bold;
    }
    .footer {
      padding: 20px 40px;
      text-align: center;
      border-top: 1px solid #f0f0f0;
    }
    .motto {
      color: #e34e26;
      font-size: 14px;
      margin-bottom: 10px;
    }
    .copyright {
      color: #999;
      font-size: 11px;
    }
  </style>
</head>
<body>
<div class="container">
  <!-- Шапка -->
  <div class="header">
    <table class="header-table">
      <tr>
        <td class="logo-cell">
          <img height="80px" src="{{ t_data.logo_url }}" alt="{{ t_data.store }}" class="logo">
        </td>
        <td class="info-cell">
          <strong>Приватне підприємство "Детта"</strong><br>
          Код в ЄДРПОУ 32071677<br>
          Телефон/факс +38 067 549 14 55<br>
          Ел. Пошта detta@detta.com.ua
        </td>
      </tr>
    </table>
  </div>

  <!-- Основний контент -->
  <div class="content">
    <h3 style="color: #000; margin-top: 0; font-size: 16px; text-align: center">{{ text_greeting }}</h3>

    <p>{{ text_change }}</p>

    <div style="text-align: center;">
      <a href="{{ reset }}" class="reset-link">Скинути пароль</a>
    </div>

    <p style="text-align: center; font-size: 14px; color: #666;">
      або скопіюйте посилання: <br>
      <span style="color: #4CAF50; word-break: break-all;">{{ reset }}</span>
    </p>

    <div style="margin-top: 30px; font-size: 12px; color: #999; border-top: 1px solid #eee; padding-top: 10px;">
      {{ text_ip }} {{ ip }}
    </div>

    <p style="margin: 40px 0 0;"><strong>{{ t_data.store }}</strong></p>
  </div>

  <!-- Футер -->
  <div class="footer">
    <div class="motto">де дружба розвиток надійність</div>
    <div class="copyright">
      &copy; {{ t_data.current_year }} {{ t_data.store }}. Всі права захищені.<br>
      <a href="{{ t_data.store_url }}" style="color: #999; text-decoration: none;">{{ t_data.store_url }}</a>
    </div>
  </div>
</div>
</body>
</html>

