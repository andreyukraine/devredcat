<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ text_received }}</title>
  <style>
    body {
      font-family: Arial, Helvetica, sans-serif;
      line-height: 1.6;
      color: #333;
      margin: 0;
      padding: 0;
      background: #fff;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
      background-image: url('{{ t_data.bg_url }}');
      background-position: top;
      background-size: cover;
      background-repeat: no-repeat;
    }
    .header {
      padding: 40px 40px 20px;
    }
    .header-table {
      width: 100%;
      border-collapse: collapse;
    }
    .logo-cell {
      width: 30%;
      vertical-align: top;
    }
    .info-cell {
      width: 70%;
      vertical-align: top;
      text-align: right;
      font-size: 11px;
      color: #333;
      line-height: 1.3;
    }
    .logo {
      max-width: 100px;
      height: auto;
    }
    .content {
      padding: 20px 40px 40px;
    }
    .table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
      border: 1px solid #DDDDDD;
    }
    .table td {
      font-size: 12px;
      border: 1px solid #DDDDDD;
      padding: 7px;
    }
    .table thead td {
      background-color: #EFEFEF;
      font-weight: bold;
      color: #222222;
    }
    .footer {
      padding: 20px 40px;
      text-align: center;
      border-top: 1px solid #f0f0f0;
    }
    .motto {
      color: #e34e26;
      font-size: 14px;
      margin-bottom: 10px;
    }
    .copyright {
      color: #999;
      font-size: 11px;
    }
  </style>
</head>
<body>
<div class="container">
  <!-- Шапка -->
  <div class="header">
    <table class="header-table">
      <tr>
        <td class="logo-cell">
          <img height="80px" src="{{ t_data.logo_url }}" alt="{{ t_data.store }}" class="logo">
        </td>
        <td class="info-cell">
          <strong>Приватне підприємство "Детта"</strong><br>
          Код в ЄДРПОУ 32071677<br>
          Телефон/факс +38 067 549 14 55<br>
          Ел. Пошта detta@detta.com.ua
        </td>
      </tr>
    </table>
  </div>

  <!-- Основний контент -->
  <div class="content">
    <h3 style="color: #000; margin-top: 0; font-size: 16px; text-align: center">{{ text_received }}</h3>
    
    <p><b>{{ text_order_id }}</b> {{ order_id }}</p>
    <p><b>{{ text_date_added }}</b> {{ date_added }}</p>
    <p><b>{{ text_order_status }}</b> {{ order_status }}</p>

    <h3 style="font-size: 16px; margin-top: 30px; border-bottom: 2px solid #003f40; padding-bottom: 5px;">{{ text_product }}</h3>
    <table class="table" style="background-color: #fff">
      <thead>
        <tr>
          <td>{{ text_product }}</td>
          <td>{{ text_model }}</td>
          <td style="text-align: right;">{{ text_quantity }}</td>
          <td style="text-align: right;">{{ text_total }}</td>
        </tr>
      </thead>
      <tbody>
        {% for product in products %}
        <tr>
          <td>{{ product.name }}
            {% if product.option %}
            {% for option in product.option %}<br />
            &nbsp;<small> - {{ option.name }} {{ option.value }}</small>{% endfor %}
            {% endif %}
          </td>
          <td>{{ product.model }}</td>
          <td style="text-align: right;">{{ product.quantity }}</td>
          <td style="text-align: right;">{{ product.total }}</td>
        </tr>
        {% endfor %}
        {% for voucher in vouchers %}
        <tr>
          <td>{{ voucher.description }}</td>
          <td></td>
          <td style="text-align: right;">1</td>
          <td style="text-align: right;">{{ voucher.amount }}</td>
        </tr>
        {% endfor %}
      </tbody>
      <tfoot>
        {% for total in totals %}
        <tr>
          <td style="text-align: right;" colspan="3"><b>{{ total.title }}:</b></td>
          <td style="text-align: right;">{{ total.value }}</td>
        </tr>
        {% endfor %}
      </tfoot>
    </table>

    {% if comment %}
    <div style="background-color: #f9f9f9; padding: 15px; border-radius: 4px; margin-top: 20px;">
      <strong>{{ text_comment }}</strong><br>
      {{ comment }}
    </div>
    {% endif %}
  </div>

  <!-- Футер -->
  <div class="footer">
    <div class="motto">де дружба розвиток надійність</div>
    <div class="copyright">
      &copy; {{ t_data.current_year }} {{ t_data.store }}. Всі права захищені.<br>
      <a href="{{ t_data.store_url }}" style="color: #999; text-decoration: none;">{{ t_data.store_url }}</a>
    </div>
  </div>
</div>
</body>
</html>
