<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ store }}</title>
  <style>
    body {
      font-family: Arial, Helvetica, sans-serif;
      line-height: 1.6;
      color: #333;
      margin: 0;
      padding: 0;
      background: #fff;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
      background-image: url('{{ t_data.bg_url }}');
      background-position: top;
      background-size: cover;
      background-repeat: no-repeat;
    }
    .header {
      padding: 40px 40px 20px;
    }
    .header-table {
      width: 100%;
      border-collapse: collapse;
    }
    .logo-cell {
      width: 30%;
      vertical-align: top;
    }
    .info-cell {
      width: 70%;
      vertical-align: top;
      text-align: right;
      font-size: 11px;
      color: #333;
      line-height: 1.3;
    }
    .logo {
      max-width: 100px;
      height: auto;
    }
    .content {
      padding: 20px 40px 40px;
    }
    .footer {
      padding: 20px 40px;
      text-align: center;
      border-top: 1px solid #f0f0f0;
    }
    .motto {
      color: #e34e26;
      font-size: 14px;
      margin-bottom: 10px;
    }
    .copyright {
      color: #999;
      font-size: 11px;
    }
  </style>
</head>
<body>
<div class="container">
  <!-- Шапка -->
  <div class="header">
    <table class="header-table">
      <tr>
        <td class="logo-cell">
          <img height="80px" src="{{ t_data.logo_url }}" alt="{{ store }}" class="logo">
        </td>
        <td class="info-cell">
          <strong>Приватне підприємство "Детта"</strong><br>
          Код в ЄДРПОУ 32071677<br>
          Телефон/факс +38 067 549 14 55<br>
          Ел. Пошта detta@detta.com.ua
        </td>
      </tr>
    </table>
  </div>

  <!-- Основний контент -->
  <div class="content">
    <h3 style="color: #000; margin-top: 0; font-size: 16px; text-align: center">{{ text_welcome }}</h3>
    
    <p>На жаль, вашу заявку на партнерську програму було відхилено.</p>
    <p>{{ contact }}</p>

    <p style="margin: 40px 0 0; font-style: italic;">Дякуємо,</p>
    <p style="margin: 5px 0 0;"><strong>{{ store }}</strong></p>
  </div>

  <!-- Футер -->
  <div class="footer">
    <div class="motto">де дружба розвиток надійність</div>
    <div class="copyright">
      &copy; {{ t_data.current_year }} {{ store }}. Всі права захищені.
    </div>
  </div>
</div>
</body>
</html>