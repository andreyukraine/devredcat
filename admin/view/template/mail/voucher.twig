<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <style>
    body {
      font-family: Arial, Helvetica, sans-serif;
      line-height: 1.6;
      color: #333;
      margin: 0;
      padding: 0;
      background: #fff;
    }
    .container {
      max-width: 600px;
      margin: 0 auto;
      background-image: url('{{ t_data.bg_url }}');
      background-position: top;
      background-size: cover;
      background-repeat: no-repeat;
    }
    .header {
      padding: 40px 40px 20px;
    }
    .header-table {
      width: 100%;
      border-collapse: collapse;
    }
    .logo-cell {
      width: 30%;
      vertical-align: top;
    }
    .info-cell {
      width: 70%;
      vertical-align: top;
      text-align: right;
      font-size: 11px;
      color: #333;
      line-height: 1.3;
    }
    .logo {
      max-width: 100px;
      height: auto;
    }
    .content {
      padding: 20px 40px 40px;
    }
    .footer {
      padding: 20px 40px;
      text-align: center;
      border-top: 1px solid #f0f0f0;
    }
    .motto {
      color: #e34e26;
      font-size: 14px;
      margin-bottom: 10px;
    }
    .copyright {
      color: #999;
      font-size: 11px;
    }
  </style>
</head>
<body>
<div class="container">
  <!-- Шапка -->
  <div class="header">
    <table class="header-table">
      <tr>
        <td class="logo-cell">
          {% if image %}
          <img height="80px" src="{{ image }}" alt="{{ store_name }}" class="logo">
          {% endif %}
        </td>
        <td class="info-cell">
          <strong>Приватне підприємство "Детта"</strong><br>
          Код в ЄДРПОУ 32071677<br>
          Телефон/факс +38 067 549 14 55<br>
          Ел. Пошта detta@detta.com.ua
        </td>
      </tr>
    </table>
  </div>

  <!-- Основний контент -->
  <div class="content">
    <h3 style="color: #000; margin-top: 0; font-size: 16px; text-align: center">{{ text_greeting }}</h3>
    
    <p>{{ text_from }}</p>

    {% if message %}
    <div style="background-color: #f9f9f9; padding: 15px; border-radius: 4px; margin: 20px 0; border-left: 4px solid #003f40;">
      <strong>{{ text_message }}</strong><br>
      {{ message }}
    </div>
    {% endif %}

    <p>{{ text_redeem }}</p>
    <p><a href="{{ store_url }}" style="color: #003f40;">{{ store_url }}</a></p>

    <p style="margin-top: 40px; margin-bottom: 0;">{{ text_footer }}</p>
  </div>

  <!-- Футер -->
  <div class="footer">
    <div class="motto">де дружба розвиток надійність</div>
    <div class="copyright">
      &copy; {{ "now"|date("Y") }} {{ store_name }}. Всі права захищені.<br>
      <a href="{{ store_url }}" style="color: #999; text-decoration: none;">{{ store_url }}</a>
    </div>
  </div>
</div>
</body>
</html>