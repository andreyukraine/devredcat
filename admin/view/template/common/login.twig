<link href="view/stylesheet/bootstrap.css" type="text/css" rel="stylesheet"/>
{#<link type="text/css" href="view/stylesheet/stylesheet.css" rel="stylesheet" media="screen"/>#}

<div class="row bg-auth">
  <div class="col-lg-6 col-md-4 hidden-xs hidden-sm" style="
    background-image: url('{{ image }}');
    background-size: cover;
    background-position: center;
    height: 100%;"></div>
  <div class="col-lg-6 col-md-8">

    <div class="bl-f-col">
      <div class="msg">
        {% if success %}
          <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
            <button type="button" class="close" data-dismiss="alert">&times;</button>
          </div>
        {% endif %}
        {% if error_warning %}
          <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
            <button type="button" class="close" data-dismiss="alert">&times;</button>
          </div>
        {% endif %}
      </div>
      <div class="bl-inp-block">
        <img class="logo-admin" src="{{ logo }}" height="50px" alt="logo"/>

        <form action="{{ action }}" class="form-auth" method="post" enctype="multipart/form-data">
          <div class="form-group">
            <label class="control-label" for="input-username">{{ entry_username }}</label>
            <input type="text" name="username" value="{{ username }}" placeholder="{{ entry_username }}"
                   id="input-username" class="form-control"/>
          </div>

          <div class="form-group">
            <label class="control-label" for="input-password">{{ entry_password }}</label>
            <input type="password" name="password" value="{{ password }}" placeholder="{{ entry_password }}"
                   id="input-password" class="form-control"/>
          </div>
          <div class="buttons-auth">
              <button type="submit" class="btn-custom">{{ button_login }}</button>
          </div>
          {% if redirect %}
            <input type="hidden" name="redirect" value="{{ redirect }}"/>
          {% endif %}
        </form>
      </div>
    </div>

  </div>
</div>
<style>

  .bl-inp-block {
    display: flex;
    padding: 30px;
    flex-direction: column;
    align-items: center;
    height: 100%;
    justify-content: center;
  }

  .logo-admin {
    width: max-content;
    margin-bottom: 30px;
  }

  .form-auth {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .buttons-auth {
    margin-top: 30px;
    width: 100%;
    text-align: center;
    display: flex;
    justify-content: center;
  }

  .btn-custom {
    border: none;
    padding: 5px 25px;
    color: #fff;
    border-radius: 7px;
    cursor: pointer;
    background-color: #003f40;
    line-height: 25px;
    align-items: center;
    justify-content: center;
    display: flex;
    vertical-align: top;
    -webkit-border-radius: 7px;
    -webkit-transition: all 0.3s ease-in-out;
  }

  .form-group {
    position: relative !important;
    margin-top: 15px !important;
    margin-bottom: 20px !important;
  }

  .form-group .form-control {
    border: none !important;
    border-bottom: 1px solid #e3e3e3 !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    background-color: transparent !important;
    padding-left: 0px !important;
    padding-top: 10px !important;
    padding-bottom: 10px !important;
    height: auto !important;
    min-height: 40px !important;
    width: 100% !important;
    outline: none !important;
    transition: all 0.2s ease !important;
    color: #000 !important;
    font-weight: normal;
  }

  .form-group .form-control:focus {
    border-bottom: 1px solid #003f40 !important;
  }

  .form-group .form-control::placeholder {
    color: transparent !important;
  }

  /* 1. СТАН МЕТКИ: ВСЕРЕДИНІ (Default) */
  .form-group .control-label {
    position: absolute !important;
    left: 0 !important;
    top: 10px;
    color: #000 !important;
    pointer-events: none !important;
    transition: all 0.2s ease !important;
    z-index: 10 !important;
    margin: 0 !important;
    padding-left: 0 !important;
  }

  /* 2. СТАН МЕТКИ: ПАРІННЯ (Floating) */
  /* Активується при фокусі або якщо поле не порожнє */
  .form-group:focus-within .control-label,
  .form-group:has(input:not(:placeholder-shown)) .control-label,
  .form-group:has(textarea:not(:placeholder-shown)) .control-label,
  .form-group:has(select option:not([value=""]):checked) .control-label {
    top: -15px !important;
    font-size: 12px;
    color: #ccc !important;
    z-index: 20 !important;
  }

  /* 3. ОСОБЛИВОСТІ SELECT */
  /* Приховуємо текст вибору за замовчуванням (щоб не накладався на метку) */
  .form-group:has(select option[value=""]:checked) select.form-control {
    color: transparent !important;
  }
  /* Показуємо текст, коли список у фокусі */
  .form-group:focus-within select.form-control {
    color: #000 !important;
  }
  /* Колір опций у самому списку */
  .form-group select option {
    color: #000 !important;
    background-color: #fff !important;
  }
  /* Приховуємо пусту опцію з випадаючого списку */
  .form-group select option[value=""] {
    display: none !important;
  }

  /* Прибираємо синій фон автозаповнення */
  input:-webkit-autofill,
  input:-webkit-autofill:hover,
  input:-webkit-autofill:focus,
  input:-webkit-autofill:active,
  .form-group .form-control:-webkit-autofill,
  .form-group .form-control:-webkit-autofill:hover,
  .form-group .form-control:-webkit-autofill:focus,
  .form-group .form-control:-webkit-autofill:active {
    -webkit-text-fill-color: #000 !important;
    transition: background-color 5000s ease-in-out 0s !important;
  }
</style>

