{{ header }}{{ column_left }} 
<div id="content">
    <div class="page-header">
        <div class="container-fluid">
            <div class="pull-right">
                <a href="{{ add_new }}" data-toggle="tooltip" title="{{ text_add_new }}" class="btn btn-primary"><i class="fa fa-plus-circle"></i></a>
                <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
            </div>
            <h1>{{ heading_title }}</h1>
            <ul class="breadcrumb">
                {% for breadcrumb in breadcrumbs %} 
                    <li><a href="{{ breadcrumb['href'] }}">{{ breadcrumb['text'] }}</a></li>
                {% endfor %} 
            </ul>
            {% if (success is defined) %} 
                <div class="alert alert-success">
                    <i class="fa fa-check-circle"></i> {{ success }} 
                </div>
            {% endif %} 
            {#
            # Start Changes to show the Free Module Message
            # @date 22-06-2024
            # @modifier Nikhil Aggarwal
            #}
            <div class="alert alert-info"><i class="fa fa-info"></i> {{ free_module_link }}</div>
            {# Changes end by Nikhil #}
            <div class="panel panel-default">
                <div class="panel-heading">

                    <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
                </div>
                <div class="panel-body" style="clear: both">
                    {{ tab_common }} 
                    <div class="tab-content"> 
                        <table class="table table-bordered table-hover">
                            <thead>
                                <tr>
                                    <td class="text-left">{{ text_name }}</td>
                                    <td class="text-left">{{ text_layout }}</td>
                                    <td class="text-left">{{text_button_layout }}</td>
                                    <td class="text-left">{{text_position }}</td>
                                    <td class="text-left">{{text_sortorder }}</td>
                                    <td class="text-left">{{entry_status }}</td>
                                    <td class="text-right">{{text_action }}</td>
                                </tr>
                            </thead>
                            <tbody>
                                {% if (modules is not empty) %} 
                                    {% for module in modules %} 
                                        <tr>
                                            <td class="text-left">{{ module['name'] }}</td>
                                            <td class="text-left">{{ module['layout_name'] }}</td>
                                            <td class="text-left">{{ module['buttonlayout'] }}</td>
                                            <td class="text-left">{% if (module['position'] == 'column_left') %}{{ text_column_left }}{% elseif (module['position'] == 'column_right') %}{{ text_column_right }}{% elseif (module['position'] == 'content_bottom') %}{{ text_content_bottom }}{% elseif (module['position'] == 'content_top') %}{{ text_content_top }}{% endif %}</td>
                                            <td class="text-left">{{ module['sortorder'] }}</td>
                                            <td class="text-left">{% if (module['status']) %}{{ text_enabled }}{% else %} {{ text_disabled }}{% endif %}</td>
                                            
                                            <td class="text-right"><a href="{{module['edit'] }}" data-toggle="tooltip" title="{{ button_edit }}" class="btn btn-primary"><i class="fa fa-pencil"></i></a>
                                            <a href="{{module['delete'] }}" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-warning"><i class="fa fa-trash-o"></i></a> </td> 
                                        </tr>
                                    {% endfor %} 
                                {% else %}       
                                    <tr>
                                        <td colspan="7" class="text-center">{{ no_result_message }}</td>
                                    </tr>
                                {% endif %} 
                            </tbody>
                        </table>    
                    </div>    
                </div>    
            </div>
        </div>
    </div>
</div>        
{{ footer }} 

