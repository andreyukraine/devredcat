                                        <option value="amazon" {% if ("amazon" in choose_login) %} {{ 'selected' }}{% endif %}>{{ text_amazon }}</option>
                                        <option value="instagram" {% if ("instagram" in choose_login) %} {{ 'selected' }}{% endif %} >{{ text_instagram }}</option>
                                        <option value="paypal" {% if ("paypal" in choose_login) %} {{ 'selected' }}{% endif %}>{{ text_paypal }}</option>
                                </select>
                                </div>
                            </div>
                            <div class="form-group"> 
                                <label class="col-sm-2 control-label" for="input-status">{{ text_icon_type }}</label>
                                <div class="col-sm-10">
                                    <select name="icon_type" id="icon_type" class="form-control">
                                        <option value="small_circular" {% if (icon_type == 'small_circular') %} {{ 'selected' }}{% endif %}>{{ text_small_circular }}</option>
                                        <option value="small_rectangular" {% if (icon_type == 'small_rectangular') %} {{ 'selected' }}{% endif %}>{{ text_small_rectangular }}</option>
