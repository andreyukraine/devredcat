                                </div>
                            </div>
                              <div class="form-group"> 
                                <label class="col-sm-2 control-label">
                                    <span class="label-tooltip" data-toggle="tooltip" data-html="true" title="" data-original-title="{{ title_choose_logins }}">
                                        {{ text_choose_logins }} 
                                    </span>
                                </label>
                                <div class="col-sm-10">
                                    <select name="choose_login[]" id="choose_login" class="form-control" multiple>
                                       
                                        <option value="facebook"  {% if ("facebook" in choose_login)  %} {{ 'selected' }}{% endif %} >{{ text_facebook }}</option>
                                        <option value="google" {% if ("google" in choose_login) %} {{ 'selected' }}{% endif %}>{{ text_google }}</option>
                                        <option value="linkedin" {% if ("linkedin" in choose_login) %} {{ 'selected' }}{% endif %}>{{ text_linkedin }}</option>
<!--                                        <option value="live" {% if ("live" in choose_login) %} {{ 'selected' }}{% endif %}>{{ text_live }}</option>-->
