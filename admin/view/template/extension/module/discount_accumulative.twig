{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <a type="submit" form="" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"
           id="save-button"><i class="fa fa-save"></i></a>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i
            class="fa fa-reply"></i></a></div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
      <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}
    {% if success %}
      <div class="alert alert-success"><i class="fa fa-exclamation-circle"></i> {{ success }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ heading_title }}</h3>
      </div>
      <div class="panel-body">
        <form method="post" enctype="multipart/form-data" id="form-accumulative-discount" class="form-horizontal">
          <div class="table-responsive">
            <table id="discount" class="table table-striped table-bordered table-hover">
              <thead>
              <tr>
                <td class="text-left col-md-2"></td>
                <td class="text-left col-md-3">Сума від</td>
                <td class="text-left col-md-3">Сума до</td>
                <td class="text-left col-md-3">Відсоток</td>
                <td class="text-left col-md-1"></td>
              </tr>
              </thead>
              <tbody>
              {% set discount_row= 0 %}
              {% for accumulative_discount in accumulative_discounts %}
                <tr id="discount-row{{ discount_row }}">
                  <td class="text-left col-md-2"></td>

                  <td class="text-left col-md-3">
                    <input type="number" name="accumulative_discount[{{ discount_row }}][amount_from]"
                           value="{{ accumulative_discount.amount_from }}" placeholder="Сумма від"
                           class="form-control row{{ discount_row }}"/>
                  </td>

                  <td class="text-left col-md-3">
                    <input type="number" name="accumulative_discount[{{ discount_row }}][amount_to]"
                           value="{{ accumulative_discount.amount_to }}" placeholder="Сумма до"
                           class="form-control row{{ discount_row }}"/>
                  </td>

                  <td class="text-left col-md-3">
                    <input type="number" name="accumulative_discount[{{ discount_row }}][percent]"
                           value="{{ accumulative_discount.percent }}" placeholder="Відсоток"
                           class="form-control row{{ discount_row }}"/>
                  </td>

                  <td class="text-left col-md-1">
                    <button type="button" onclick="$('#discount-row{{ discount_row }}').remove();" data-toggle="tooltip"
                            title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i>
                    </button>
                  </td>
                </tr>
                {% set discount_row =  discount_row + 1 %}
              {% endfor %}
              </tbody>
              <tfoot>
              <tr>
                <td colspan="5"></td>
                <td class="text-left">
                  <button type="button" onclick="addDiscount();" data-toggle="tooltip" title="{{ button_add }}"
                          class="btn btn-primary"><i class="fa fa-plus-circle"></i></button>
                </td>
              </tr>
              </tfoot>
            </table>
          </div>
        </form>
        <a class="btn btn-default" id="back-btn" href="{{ back_link }}"> < Back</a>
      </div>
    </div>
  </div>
  <script type="text/javascript"><!--

    var discount_row = {{ discount_row }};

    function addDiscount() {
      html = '<tr id="discount-row' + discount_row + '">';
      html += '<td class="text-left col-md-2"></td>';
      html += '<td class="text-left col-md-3"><input type="number" name="accumulative_discount[' + discount_row + '][amount_from]" value="" placeholder="Сумма від" class="form-control" /></td>';
      html += '<td class="text-left col-md-3"><input type="number" name="accumulative_discount[' + discount_row + '][amount_to]" value="" placeholder="Сумма до" class="form-control" /></td>';
      html += '<td class="text-left col-md-3"><input type="number" name="accumulative_discount[' + discount_row + '][percent]" value="" placeholder="Відсоток" class="form-control" /></td>';
      html += '<td class="text-left col-md-1"></td>';
      html += '</tr>';

      $('#discount tbody').append(html);

      $('.date').datetimepicker({
        pickTime: false
      });

      $('.selectpicker').selectpicker({
        size: 'auto',
        container: 'body',
        dropdownAlignRight: 'auto',
        dropupAuto: false,
        deselectAllText: '{{ text_unselect_all }}',
        selectAllText: '{{ text_select_all }}',
        iconBase: 'fa',
        tickIcon: 'fa-check',
        selectedTextFormat: 'count > 3',
        showTick: true
      });

      discount_row++;
    }


    {% if permission %}
    $('#save-button').click(function () {

      $.ajax({
        url: 'index.php?route=extension/module/discounts_pack/discount_accumulative/saveDiscount&user_token={{ user_token }}',
        type: 'post',
        dataType: 'json',
        beforeSend: function () {
          $('.alert').remove();
        },
        data: {
          setting: $("#form-settings").serialize(),
          accumulative_discount: $('#form-accumulative-discount').serialize(),
        },
        success: function (json) {
          alertJson('alert alert-success', json);
        },
        error: function (json) {
          alertJson('alert alert-warning', json);
        }
      });

      return false;
    });
    {% else %}
    $('#save-button').click(function () {
      $('.alert').remove();
      $(".panel").filter(':first').before('<div class="alert alert-warning">{{ error_permission }}</div>');
    });
    {% endif %}

    function alertJson(action, json) {

      $('.alert').remove();

      if (json['success']) {
        $(".panel").filter(':first').before('<div class="' + action + '">' + json['success'] + '</div>');
      } else if (json['error']) {
        $(".panel").filter(':first').before('<div class="' + action + '">' + json['error'] + '</div>');
      }

    }
    //--></script>
</div>
{{ footer }}
