                    // -------------------------- вибір товарів -------------------------------


                    $(document).ready(function () {
                      // Глобальна змінна для відстеження поточного поля вводу
                      var currentInputField = null;

                      // Ініціалізація автозаповнення для полів вводу товарів
                      $('input[name="productsInput"]').autocomplete({
                        source: function (request, response) {
                          $.ajax({
                            url: 'index.php?route=catalog/product/autocomplete&user_token={{ user_token }}&filter_name=' + encodeURIComponent(request),
                            dataType: 'json',
                            success: function (json) {
                              response($.map(json, function (item) {
                                return {
                                  label: item['name'],
                                  value: item['product_id'],
                                  price: item.price,
                                  special: item.special || 0,
                                  option: item.option || false,
                                  options: item.options || []
                                }
                              }));
                            }
                          });
                        },
                        select: function (item) {
                          currentInputField = $(this);
                          var bundle_id = $(this).closest('tr').find('.bundle_id').val();
                          if (item.option && item.option.length > 0) {
                            showOptionsModal(item, bundle_id);
                          } else {
                            // Якщо опцій немає - додаємо товар відразу
                            var real_price = item.special > 0 ? item.special : item.price;
                            addProductToBundle(item, bundle_id, real_price);
                          }
                        }
                      });

                      // Функція показу модального вікна з опціями
                      function showOptionsModal(item, bundle_id) {

                        // Удаляем предыдущее модальное окно, если оно есть
                        $('#optionsModal').remove();

                        // Створюємо HTML для модального вікна
                        var modalHTML = `
                        <div class="modal fade" id="optionsModal" tabindex="-1" role="dialog">
                            <div class="modal-dialog" role="document">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <button type="button" class="close" data-dismiss="modal">&times;</button>
                                        <h4 class="modal-title">Оберіть опції для: ${item.label}</h4>
                                    </div>
                                    <div class="modal-body" id="optionsContainer">
                                        ${generateOptionsHTML(item.option)}
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-primary" id="confirmOptions">Підтвердити</button>
                                        <button type="button" class="btn btn-default" data-dismiss="modal">Скасувати</button>
                                    </div>
                                </div>
                            </div>
                        </div>`;

                        // Додаємо модальне вікно на сторінку
                        $('body').append(modalHTML);

                        // Показуємо модальне вікно
                        $('#optionsModal').modal('show');

                        // Обробник підтвердження вибору
                        $('#confirmOptions').off('click').on('click', function () {
                          var selectedOptions = getSelectedOptions();

                          $('input[name="productsInput"]')
                            .val("")
                            .autocomplete("close");

                          console.log(selectedOptions);

                          // Додаємо інформацію про опції до товару
                          item.selectedOptions = selectedOptions;

                          // Додаємо товар до комплекту
                          //addProductToBundle(item, bundle_id, finalPrice);

                          // Закриваємо модальне вікно
                          $('#optionsModal').modal('hide').on('hidden.bs.modal', function() {
                            $(this).remove();
                          });
                        });
                      }

                      // Генерація HTML для опцій
                      function generateOptionsHTML(options) {
                        var html = '';
                        if (!options || options.length === 0) return '<p>Опції не знайдено</p>';
                        options.forEach(function (option) {
                            html += `<div class="form-group">
                            <label>${option.name}</label>
                            <select class="form-control option-select" data-option-id="${option.product_option_id}">`;
                                if (option.product_option_value && option.product_option_value.length > 0) {
                                  option.product_option_value.forEach(function (value) {
                                    html += `<option value="${value.product_option_value_id}" data-price-prefix="${value.price_prefix}" data-price="${value.price}">${value.name}(${value.price_prefix}${value.price})</option>`;
                                  });
                                } else {
                                  html += '<option value="">Немає варіантів</option>';
                                }
                            html += `</select></div>`;
                        });
                        return html;
                      }

                      // Отримання вибраних опцій
                      function getSelectedOptions() {
                        var selected = [];
                        $('.option-select').each(function () {
                          var optionId = $(this).data('option-id');
                          var valueId = $(this).val();
                          var option = $(this).find('option:selected');
                          if (valueId) {
                            selected.push({
                              option_id: optionId,
                              value_id: valueId,
                              price_prefix: option.data('price-prefix'),
                              price: parseFloat(option.data('price')) || 0
                            });
                          }
                        });
                        return selected;
                      }

                      // Функція додавання товару до комплекту
                      function addProductToBundle(item, bundle_id, price) {
                        var optionsIcon = item.option ? '<i class="fa fa-tags"></i> ' : '';
                        var optionsHTML = '';

                        // Додаємо приховані поля для опцій, якщо вони є
                        if (item.selectedOptions && item.selectedOptions.length > 0) {
                          item.selectedOptions.forEach(function (opt, index) {
                            optionsHTML += `
                            <input type="hidden" name="productbundles_custom[${bundle_id}][options][${item.value}][${index}][option_id]" value="${opt.option_id}">
                            <input type="hidden" name="productbundles_custom[${bundle_id}][options][${item.value}][${index}][value_id]" value="${opt.value_id}">`;
                          });
                        }

                        var productHtml = `
                        <div id="product-bundle_${bundle_id}_${item.value}">
                            ${optionsIcon}${item.label} -
                            {% if currencyAlignment == "L" %}{{ currency }}{% endif %}
                            ${price}
                            {% if currencyAlignment == "R" %}{{ currency }}{% endif %}
                            <i class="fa fa-minus-circle removeIcon" product_price="${price}"></i>
                            <input type="hidden" name="productbundles_custom[${bundle_id}][products][]" value="${item.value}" />
                            ${optionsHTML}
                        </div>`;

                        currentInputField.closest('td').find('.scrollbox').append(productHtml);
                        updateTotalPrice(bundle_id, price);
                      }

                      // Оновлення загальної ціни комплекту
                      function updateTotalPrice(bundle_id, price) {
                        var totalElement = $('#product-bundle-totalprice_' + bundle_id);
                        var currentTotal = parseFloat(totalElement.text()) || 0;
                        var newTotal = (currentTotal + parseFloat(price)).toFixed(2);

                        totalElement.text(newTotal);
                        $('input[name="productbundles_custom[' + bundle_id + '][totalprice]"]').val(newTotal);
                      }

                      // Видалення товару з комплекту
                      $(document).on('click', '.removeIcon', function () {
                        var bundle_id = $(this).closest('tr').find('.bundle_id').val();
                        var price = parseFloat($(this).attr('product_price'));
                        var currentTotal = parseFloat($('#product-bundle-totalprice_' + bundle_id).text());

                        $(this).parent().remove();
                        $('#product-bundle-totalprice_' + bundle_id).text((currentTotal - price).toFixed(2));
                        $('input[name="productbundles_custom[' + bundle_id + '][totalprice]"]').val((currentTotal - price).toFixed(2));
                      });
                    });

                    // -------------------------- end -------------------------------


                    $('.scrollbox.first').delegate('.fa-minus-circle', 'click', function () {
                      var bundle_id = $(this).parents('tr').find('.bundle_id').val();
                      var remove_price = $(this).attr("product_price");
                      $(this).parent().remove();
                      var RemovePrice = (parseFloat($('#product-bundle-totalprice_' + bundle_id).html()) - parseFloat(remove_price)).toFixed(2);
                      $('#product-bundle-totalprice_' + bundle_id).html(RemovePrice);
                      $('input[name=\'productbundles_custom[' + bundle_id + '][totalprice]\']').val(RemovePrice);
                    });

                    // Show in Products
                    $('input[name=\'productsShow_Input\']').autocomplete({
                      delay: 500,
                      source: function (request, response) {
                        $.ajax({
                          url: 'index.php?route=catalog/product/autocomplete&user_token={{ user_token }}&store_id={{ store.store_id }}&filter_name=' + encodeURIComponent(request),
                          dataType: 'json',
                          success: function (json) {
                            response($.map(json, function (item) {
                              return {
                                label: item.name,
                                value: item.product_id,
                                price: item.price,
                                special: item.special
                              }
                            }));
                          }
                        });
                      },
                      select: function (item) {
                        var bundle_id = currentProductsShowObject.parents('tr').find('.bundle_id').val();
                        currentProductsShowObject.parent().find('#product-bundle-productsShow_' + bundle_id + '_' + item.value).remove();
                        currentProductsShowObject.parent().find('.second').append(
                          '<div id="product-bundle-productsShow_' + bundle_id + '_' + item.value + '">' +
                          item.label +
                          '<i class="fa fa-minus-circle removeIcon"></i>' +
                          '<input type="hidden" name="productbundles_custom[' + bundle_id + '][productsShow][]" value="' + item.value + '" />' +
                          '</div>'
                        );

                        currentProductsShowObject.parent().find('#product-bundle-productsShow_' + bundle_id + ' div:odd').attr('class', 'odd');
                        currentProductsShowObject.parent().find('#product-bundle-productsShow_' + bundle_id + ' div:even').attr('class', 'even');
                      }
                    });

                    $('.scrollbox.second').delegate('.fa-minus-circle', 'click', function () {
                      var bundle_id = $(this).parents('tr').find('.bundle_id').val();
                      $(this).parent().remove();
                      $(this).parent().find('#product-bundle-productsShow_' + bundle_id + ' div:odd').attr('class', 'odd');
                      $(this).parent().find('#product-bundle-productsShow_' + bundle_id + ' div:even').attr('class', 'even');
                    });

                    // Show in Categories
                    $('input[name=\'categoriesShow_Input\']').autocomplete({
                      delay: 500,
                      source: function (request, response) {
                        $.ajax({
                          url: 'index.php?route=catalog/category/autocomplete&user_token={{ user_token }}&filter_name=' + encodeURIComponent(request),
                          dataType: 'json',
                          success: function (json) {
                            response($.map(json, function (item) {
                              return {
                                label: item.name,
                                value: item.category_id
                              }
                            }));
                          }
                        });
                      },
                      select: function (item) {
                        var bundle_id = currentcategoriesShowObject.parents('tr').find('.bundle_id').val();
                        currentcategoriesShowObject.parent().find('#product-bundle-categoriesShow_' + bundle_id + '_' + item.value).remove();
                        currentcategoriesShowObject.parent().find('.third').append(
                          '<div id="product-bundle-categoriesShow_' + bundle_id + '_' + item.value + '">' +
                          item.label +
                          '<i class="fa fa-minus-circle removeIcon"></i>' +
                          '<input type="hidden" name="productbundles_custom[' + bundle_id + '][categoriesShow][]" value="' + item.value + '" />' +
                          '</div>'
                        );

                        currentcategoriesShowObject.parent().find('#product-bundle-categoriesShow_' + bundle_id + ' div:odd').attr('class', 'odd');
                        currentcategoriesShowObject.parent().find('#product-bundle-categoriesShow_' + bundle_id + ' div:even').attr('class', 'even');
                      }
                    });

                    $('.scrollbox.third, .scrollbox.second').delegate('.fa-minus-circle', 'click', function () {
                      var bundle_id = $(this).parents('tr').find('.bundle_id').val();
                      $(this).parent().remove();
                      $(this).parent().find('#product-bundle-categoriesShow_' + bundle_id + ' div:odd').attr('class', 'odd');
                      $(this).parent().find('#product-bundle-categoriesShow_' + bundle_id + ' div:even').attr('class', 'even');
                    });
                  }

                  initializeAutocomplete();
                </script>
