    function checkCronStatus() {
      $.ajax({
        url: 'index.php?route=extension/module/ocimport/checkCronStatus&user_token={{ user_token }}',
        type: 'get',
        dataType: 'json',
        success: function (json) {

          console.log(json);

          if (json['success']) {
            $('#cronJobResult').html('<div class="alert alert-success">' + json['success'] + '</div>');
          } else if (json['load']) {
            $('#cronJobResult').html('<div class="alert alert-info">' + json['load'] + '</div>');
          } else if (json['error']) {
            $('#cronJobResult').html('<div class="alert alert-danger">' + json['error'] + '</div>');
          } else if (json['status']) {
            $('#cronJobResult').html('<div class="alert alert-info">' + json['status'] + '</div>');

            if (json['progress']) {
              $('#cronJobResult').append('<pre>' + json['progress'] + '</pre>');
            }
            setTimeout(checkCronStatus, 100);
          }
        },
        error: function (xhr, ajaxOptions, thrownError) {
          $('#cronJobResult').html('<div class="alert alert-danger">Error: ' + xhr.responseText + '</div>');
        }
      });
    }
  });
