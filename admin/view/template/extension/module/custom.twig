                        </div>
                        {% if method.code == 'np' %}
                          <div style="margin-top: 10px; border-top: 1px solid #eee; padding-top: 5px;">
                            <strong>Поштомат</strong>
                            <div style="max-height: 100px; overflow-y: auto;">
                            {% for customer_group in customer_groups %}
                              <div class="input-group input-group-sm">
                                <span class="input-group-addon" style="width: 50%;">{{ customer_group.name }}</span>
                                <input type="text" name="module_custom_shipping[methods][{{ shipping_key }}][cost_postomat][{{ customer_group.customer_group_id }}]"
                                       value="{{ method.cost_postomat[customer_group.customer_group_id] ?? '' }}" placeholder="0" class="form-control"/>
                              </div>
                            {% endfor %}
                            </div>
