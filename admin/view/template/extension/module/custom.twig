            </div>

            <div class="tab-pane" id="tab-payment">

              <input type="hidden" name="module_custom_payment[status]" value="1">

              <table id="payment-methods" class="table table-striped table-bordered table-hover">
                <thead>
                <tr>
                  <td>Назва способу</td>
                  <td class="text-left">{{ column_field }}</td>
                  <td>Комісія</td>
                  <td>{{ column_custumer_group }}</td>
                  <td>Статус</td>
                  <td>Сортування</td>
                  <td>Опис</td>
                  <td width="56px"></td>
                </tr>
                </thead>
                <tbody>
                {% set payment_key = 0 %}
                {% if module_custom_payment.methods %}
                  {% for method in module_custom_payment.methods %}
                    <tr id="payment-method-{{ payment_key }}">
                      <!-- Назва способу (text input) -->
                      <td>
                        {% for lang in langs %}
                          <div class="lang-field">
                              <span class="lang-indicator">
                                {{ lang.code }}
                              </span>
                            <input
                              type="text"
                              name="module_custom_payment[methods][{{ payment_key }}][title][{{ lang.language_id }}][title]"
                              class="form-control"
                              value="{% for key_l, title in method.title %}{% if key_l == lang.language_id %}{{ title.title }}{% endif %}{% endfor %}"
                              placeholder="Назва способу"
                            />
                          </div>
                        {% endfor %}
                      </td>

                      <!-- Спосіб оплати (select) -->
                      <td>
                        <select name="module_custom_payment[methods][{{ payment_key }}][code]" class="form-control">
                          {% for item in module_custom_payment.list %}
                            <option value="{{ item.code }}" {{ item.code == method.code ? 'selected' }}>
                              {{ item.label }}
                            </option>
                          {% endfor %}
                        </select>
                      </td>

                      <!-- Комісія (%) -->
                      <td width="30px">
                        <input
                          type="number"
                          name="module_custom_payment[methods][{{ payment_key }}][fee]"
                          class="form-control"
                          value="{{ method.fee ?? 0 }}"
                          min="0"
                          step="0.1"
                        />
                      </td>

                      <!-- Групи клієнтів (checkboxes) -->
                      <td>
                        {% set customer_group_row = 0 %}
                        {% for customer_group in customer_groups %}
                          <div class="checkbox">
                            <label>
                              <input
                                type="checkbox"
                                name="module_custom_payment[methods][{{ payment_key }}][customer_group][{{ customer_group_row }}]"
                                value="{{ customer_group.customer_group_id }}"
                                {{ method.customer_group and (customer_group.customer_group_id in method.customer_group) ? 'checked' }}
                              />
                              {{ customer_group.name }}
                            </label>
                          </div>
                          {% set customer_group_row = customer_group_row + 1 %}
                        {% endfor %}
                      </td>

                      <!-- Статус (активний/неактивний) -->
                      <td>
                        <select name="module_custom_payment[methods][{{ payment_key }}][status]" class="form-control">
                          <option value="1" {{ (method.status ?? 1) == 1 ? 'selected' }}>Активний</option>
                          <option value="0" {{ (method.status ?? 1) == 0 ? 'selected' }}>Неактивний</option>
                        </select>
                      </td>

                      <!-- Сортування -->
                      <td width="30px">
                        <input
                          type="number"
                          name="module_custom_payment[methods][{{ payment_key }}][sort_order]"
                          class="form-control"
                          value="{{ method.sort_order ?? 0 }}"
                        />
                      </td>

                      <td width="300px">
                        {% for lang in langs %}
                          <div class="col-lg-12">
                            <div class="lang-field">
                              <span class="lang-indicator">
                                {{ lang.code }}
                              </span>
                              <textarea name="module_custom_payment[methods][{{ payment_key }}][descs][{{ lang.language_id }}][desc]" rows="5" placeholder="Desc" id="input-shipping-desc{{ lang.language_id }}" class="form-control">{% for key_l, descs in method.descs %}{% if key_l == lang.language_id %}{{ descs.desc }}{% endif %}{% endfor %}</textarea>
                            </div>
                          </div>
                        {% endfor %}
                      </td>

                      <!-- Кнопка видалення -->
                      <td>
                        <button
                          type="button"
                          onclick="$('#payment-method-{{ payment_key }}').remove()"
                          class="btn btn-danger"
                          title="Видалити">
                          <i class="fa fa-minus-circle"></i>
                        </button>
                      </td>
                    </tr>
                    {% set payment_key = payment_key + 1 %}
                  {% endfor %}
                {% endif %}
                </tbody>
                <tfoot>
                <td colspan="7"></td>
                <td>
                  <button type="button" onclick="addPaymentMethod()" data-toggle="tooltip" title=""
                          class="btn btn-primary" data-original-title="Добавить поле"><i class="fa fa-plus-circle"></i>
                  </button>
                </td>
                </tfoot>
              </table>

              <script>
                var payment_key = {{ payment_key }};

                function addPaymentMethod() {

                  html = '<tr id="payment-method-' + payment_key + '">';
                  html += '<td>';
                  {% for lang in langs %}
                  html += '<div class="lang-field"><span class="lang-indicator">{{ lang.code }}</span>'
                  html += '<input type="text" name="module_custom_payment[methods][{{ payment_key }}][descs][{{ lang.language_id }}][title]" class="form-control" value="{% for key_l, descs in method.descs %}{% if key_l == lang.language_id %}{{ descs.title }}{% endif %}{% endfor %}" placeholder="Назва способу" /></div>';
                  {% endfor %}
                  html += '</td>';
                  html += '<td><select name="module_custom_payment[methods][' + payment_key + '][code]" id="input-payment-method-' + payment_key + '" class="form-control">';
                  {% for name, item in module_custom_payment.list %}
                  html += '<option value="{{ item.code }}" >{{ item.label }}';
                  {% endfor %}
                  html += '</select></td>';
                  html += '<td>';
                  html += '<input type="number" name="module_custom_payment[methods][{{ payment_key }}][fee]" class="form-control" value="{{ method.fee ?? 0 }}" min="0" step="0.1" />';
                  html += '</td>';
                  html += '<td>';
                  {% set customer_group_row = 0 %}
                  {% for customer_group in customer_groups %}
                  html += '<div class="checkbox"><label><input type="checkbox" name="module_custom_payment[methods][' + payment_key + '][customer_group][{{ customer_group_row }}]" value="{{ customer_group.customer_group_id }}" />{{ customer_group.name }}</label></div>';
                  {% set customer_group_row = customer_group_row + 1 %}
                  {% endfor %}
                  html += '</td>';

                  html += '<td>';
                  html += '<select name="module_custom_payment[methods][{{ payment_key }}][status]" class="form-control">';
                  html += '<option value="1" {{ (method.status ?? 1) == 1 ? 'selected' }}>Активний</option>;'
                  html += '<option value="0" {{ (method.status ?? 1) == 0 ? 'selected' }}>Неактивний</option>;'
                  html += '</select>';
                  html += '</td>';

                  html += '<td>';
                  html += '<input type="number" name="module_custom_payment[methods][{{ payment_key }}][sort_order]" class="form-control" value="{{ method.sort_order ?? 0 }}" />';
                  html += '</td>';


                  html += '<td>';
                    {% for lang in langs %}
                      html += '<div class="col-lg-12">';
                      html += '<div class="lang-field">';
                      html += '<span class="lang-indicator">{{ lang.code }}';
                      html += '</span>';
                      html += '<textarea name="module_custom_payment[methods][{{ payment_key }}][descs][{{ lang.language_id }}][desc]" rows="5" placeholder="Desc" id="input-shipping-desc{{ lang.language_id }}" class="form-control">{% for key_l, descs in method.descs %}{% if key_l == lang.language_id %}{{ descs.desc }}{% endif %}{% endfor %}</textarea>';
                      html += '</div>';
                      html += '</div>';
                    {% endfor %}
                  html += '</td>';


                  html += '<td><button type="button" onclick="jQuery(\'#payment-method-' + payment_key + '\').remove();" data-toggle="tooltip" title="Удалить" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
                  html += '</tr>';

                  jQuery('#payment-methods').append(html);
                  payment_key++;
                };
              </script>

            </div>

            <div class="tab-pane" id="tab-comment">
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-comment-status">{{ entry_view }}</label>
                <div class="col-sm-10">
                  <select name="module_custom_comment[status]" id="input-comment-status" class="form-control">
                    {% if module_custom_comment.status %}
                      <option value="1" selected="selected">{{ text_yes }}</option>
                      <option value="0">{{ text_no }}</option>
                    {% else %}
                      <option value="1">{{ text_yes }}</option>
                      <option value="0" selected="selected">{{ text_no }}</option>
                    {% endif %}
                  </select>
                </div>
              </div>
            </div>

            <div class="tab-pane" id="tab-module">
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-module-status">{{ entry_view }}</label>
                <div class="col-sm-10">
                  <select name="module_custom_module[status]" id="input-module-status" class="form-control">
                    {% if module_custom_module.status %}
                      <option value="1" selected="selected">{{ text_yes }}</option>
                      <option value="0">{{ text_no }}</option>
                    {% else %}
                      <option value="1">{{ text_yes }}</option>
                      <option value="0" selected="selected">{{ text_no }}</option>
                    {% endif %}
                  </select>
                </div>
              </div>
            </div>

            <div class="tab-pane" id="tab-total">
              <div class="form-group">
                <label class="col-sm-2 control-label" for="input-total-status">{{ entry_view }}</label>
                <div class="col-sm-10">
                  <select name="module_custom_total[status]" id="input-total-status" class="form-control">
                    {% if module_custom_total.status %}
                      <option value="1" selected="selected">{{ text_yes }}</option>
                      <option value="0">{{ text_no }}</option>
                    {% else %}
                      <option value="1">{{ text_yes }}</option>
                      <option value="0" selected="selected">{{ text_no }}</option>
                    {% endif %}
                  </select>
                </div>
              </div>
            </div>
          </div>

        </form>
      </div>
    </div>


  </div>
</div>
