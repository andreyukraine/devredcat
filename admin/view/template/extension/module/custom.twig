                                <input type="text" name="module_custom_shipping[methods][{{ shipping_key }}][free_address][{{ customer_group.customer_group_id }}]"
                                       value="{{ method.free_address[customer_group.customer_group_id] ?? '' }}" placeholder="1000" class="form-control"/>
                              </div>
                            {% endfor %}
                            </div>
                          </div>
                        {% endif %}
                      </td>

                      <td>
                        {% if method.code == 'np' %}<strong>На відділення</strong>{% endif %}
                        <div style="overflow-y: auto; min-width: 200px;">
                        {% for customer_group in customer_groups %}
                          <div class="input-group input-group-sm">
                            <span class="input-group-addon" style="width: 50%;">{{ customer_group.name }}</span>
