                            {% for customer_group in customer_groups %}
                              <div class="input-group input-group-sm">
                                <span class="input-group-addon" style="width: 50%;">{{ customer_group.name }}</span>
                                <input type="text" name="module_custom_shipping[methods][{{ shipping_key }}][cost_address][{{ customer_group.customer_group_id }}]"
