    function addDiscount() {


      html = '<tr id="discount-row' + discount_row + '" data-row-number="' + discount_row + '">';
      html += '  <td class="text-left"><select name="product_discount[' + discount_row + '][product_id]" class="form-control selectpicker product-discount-select"  data-live-search="true">';
      {% for product in products %}
      html += '    <option value="{{ product.product_id }}">{{ product.name|e }}</option>';
      {% endfor %}
      html += '  </select></td>';


      html += ' <td class="text-center bl-ops' + discount_row + '"><table class="table-sm table-striped table-opts">';
      {% for option in opts_add_js %}
      html += '  <tr><td><span>{{ option.name }}</span></td>';
      html += '  <td><select name="product_discount[' + discount_row + '][options][{{ option.option_id }}]" class="form-control row' + discount_row + ' selectpicker" data-live-search="true">';
      {% for option_value in option.values %}
      html += '  <option value="{{ option_value.option_value_id }}">{{ option_value.name }}</option>';
      {% endfor %}
      html += '  </select></td></tr>';
      {% endfor %}
      html += '  </table></td>';


      html += '  <td class="text-left"><select name="product_discount[' + discount_row + '][customer_group_id]" class="form-control selectpicker"  data-live-search="true">';
      {% for customer_group in customer_groups %}
      html += '    <option value="{{ customer_group.customer_group_id }}">{{ customer_group.name|e('js') }}</option>';
      {% endfor %}
      html += '  </select></td>';
      html += '  <td class="text-right"><input type="text" name="product_discount[' + discount_row + '][priority]" value="" placeholder="{{ entry_priority }}" class="form-control" /></td>';
      html += '  <td class="text-right"><input type="text" name="product_discount[' + discount_row + '][percentage]" value="" placeholder="{{ entry_percentage }}" class="form-control" /></td>';
      html += '  <td class="text-right"><input type="text" name="product_discount[' + discount_row + '][price]" value="" placeholder="{{ entry_price }}" class="form-control" /></td>';
      html += '  <td class="text-right"><input type="text" name="product_discount[' + discount_row + '][qty]" value="" placeholder="{{ entry_qty }}" class="form-control" /></td>';
      html += '  <td class="text-left"><table><tr><td><div class="input-group date"><input type="text" name="product_discount[' + discount_row + '][date_start]" value="" placeholder="{{ entry_date_start }}" data-date-format="YYYY-MM-DD" class="form-control" /><span class="input-group-btn"><button type="button" class="btn btn-default"><i class="fa fa-calendar"></i></button></span></div></td></td></tr>';
      html += '  <tr><td><div class="input-group date"><input type="text" name="product_discount[' + discount_row + '][date_end]" value="" placeholder="{{ entry_date_end }}" data-date-format="YYYY-MM-DD" class="form-control" /><span class="input-group-btn"><button type="button" class="btn btn-default"><i class="fa fa-calendar"></i></button></span></div></td></tr></table>';
      html += '  <td class="text-left"><button type="button" onclick="$(\'#discount-row' + discount_row + '\').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
      html += '</tr>';

      $('#discount .list').append(html);

      $('.date').datetimepicker({
        pickTime: false
      });

      init();

      discount_row++;

    }

    $('#save-button').click(function () {

      $.ajax({
        url: 'index.php?route=extension/module/discounts_pack/discount_product/saveDiscount&user_token={{ user_token }}',
        type: 'post',
        dataType: 'json',
        beforeSend: function () {
          $('.alert').remove();
        },
        data: {
          setting: $("#form-settings").serialize(),
          product_discount: $('#form-product-discount').serialize(),
        },
        success: function (json) {
          alertJson('alert alert-success', json);
        },
        error: function (json) {
          alertJson('alert alert-warning', json);
        }
      });

      return false;
    });

    function alertJson(action, json) {

      $('.alert').remove();

      if (json['success']) {
        $(".panel").before('<div class="' + action + '">' + json['success'] + '</div>');
      } else if (json['error']) {
        $(".panel").before('<div class="' + action + '">' + json['error'] + '</div>');
      }

    }

    $('.date').datetimepicker({
      pickTime: false
    });

    $('.time').datetimepicker({
      pickDate: false
    });

    $('.datetime').datetimepicker({
      pickDate: true,
      pickTime: true
    });


    //--></script>
</div>
{{ footer }}
