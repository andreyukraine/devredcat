{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <a type="submit" form="" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"
           id="save-button"><i class="fa fa-save"></i></a>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i
            class="fa fa-reply"></i></a></div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
      <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}
    {% if success %}
      <div class="alert alert-success"><i class="fa fa-exclamation-circle"></i> {{ success }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ heading_title }}</h3>
      </div>
      <div class="panel-body">
        <form method="post" enctype="multipart/form-data" id="form-settings" class="form-horizontal">
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
            <div class="col-sm-10">
              <select name="total_product_discount_status" id="input-status" class="setting form-control selectpicker">
                {% if product_discount_status %}
                  <option value="1" selected="selected">{{ text_enabled }}</option>
                  <option value="0">{{ text_disabled }}</option>
                {% else %}
                  <option value="1">{{ text_enabled }}</option>
                  <option value="0" selected="selected">{{ text_disabled }}</option>
                {% endif %}
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-sort-order">{{ entry_sort_order }}</label>
            <div class="col-sm-10">
              <input type="text" name="total_product_discount_sort_order" value="{{ product_discount_sort_order }}"
                     placeholder="{{ entry_sort_order }}" id="input-sort-order" class="setting form-control"/>
            </div>
          </div>
        </form>
        <form method="post" enctype="multipart/form-data" id="form-product-discount" class="form-horizontal">
          <div>
            <table id="discount" class="table table-striped table-bordered table-hover">
              <thead>
              <tr>
                <td class="text-left col-md-3">{{ entry_product }}</td>
                <td class="text-left col-md-2">{{ entry_option }}</td>
                <td class="text-left col-md-1">{{ entry_customer_group }}</td>
                <td class="text-right col-md-1">{{ entry_priority }}</td>
                <td class="text-right col-md-1">%</td>
                <td class="text-right col-md-1">{{ entry_price }}</td>
                <td class="text-left col-md-1">{{ entry_qty }}</td>
                <td class="text-left col-md-1">Time</td>
                <td></td>
              </tr>
              </thead>
              <tbody class="list">
              {% set discount_row= 0 %}
              {% for product_discount in product_discounts %}
                <tr id="discount-row{{ discount_row }}" data-row-number="{{ discount_row }}">
                  <td class="text-left">
                    <select name="product_discount[{{ discount_row }}][product_id]"
                            class="form-control row{{ discount_row }} selectpicker product-discount-select" data-live-search="true">
                      {% for product in products %}
                        {% if product.product_id  ==  product_discount.product_id %}
                          <option value="{{ product.product_id }}" selected="selected">{{ product.name }}</option>
                        {% else %}
                          <option value="{{ product.product_id }}">{{ product.name }}</option>
                        {% endif %}
                      {% endfor %}
                    </select>
                  </td>

                  <td class="text-center bl-ops{{ discount_row }} table-responsive">
                    <table class="table-sm table-striped table-opts">
                      {% for option in product_discount.options %}
                        <tr>
                          <td><span>{{ option.name }}</span></td>
                          <td>
                            <select name="product_discount[{{ discount_row }}][options][{{ option.option_id }}]" class="form-control row{{ discount_row }} selectpicker" data-live-search="true">
                              {% for option_value in option.values %}
                                {% if option_value.selected %}
                                  <option value="{{ option_value.option_value_id }}" selected="selected">{{ option_value.name }}</option>
                                {% else %}
                                  <option value="{{ option_value.option_value_id }}">{{ option_value.name }}</option>
                                {% endif %}
                              {% endfor %}
                            </select>
                          </td>
                        </tr>
                      {% endfor %}
                    </table>
                  </td>

                  <td class="text-left">
                    <select name="product_discount[{{ discount_row }}][customer_group_id]"
                            class="form-control row{{ discount_row }} selectpicker" data-live-search="true">
                      {% for customer_group in customer_groups %}
                        {% if customer_group.customer_group_id  ==  product_discount.customer_group_id %}
                          <option value="{{ customer_group.customer_group_id }}"
                                  selected="selected">{{ customer_group.name }}</option>
                        {% else %}
                          <option value="{{ customer_group.customer_group_id }}">{{ customer_group.name }}</option>
                        {% endif %}
                      {% endfor %}
                    </select></td>
                  <td class="text-right">
                    <input type="text" name="product_discount[{{ discount_row }}][priority]"
                                                value="{{ product_discount.priority }}"
                                                placeholder="{{ entry_priority }}"
                                                class="form-control row{{ discount_row }}"/>
                  </td>
                  <td class="text-right">
                    <input type="text" name="product_discount[{{ discount_row }}][percentage]"
                                                value="{{ product_discount.percentage }}"
                                                placeholder="{{ entry_percentage }}"
                                                class="form-control row{{ discount_row }}"/>
                  </td>
                  <td class="text-right">
                    <input type="text" name="product_discount[{{ discount_row }}][price]"
                           value="{{ product_discount.price }}"
                           placeholder="{{ entry_price }}"
                           class="form-control row{{ discount_row }}"/>
                  </td>
                  <td class="text-right">
                    <input type="text" name="product_discount[{{ discount_row }}][qty]"
                                                value="{{ product_discount.qty }}" placeholder="{{ entry_qty }}"
                                                class="form-control row{{ discount_row }}"/>
                  </td>
                  <td class="text-left" style="width: 20%;">
                    <table>
                      <tr>
                        <td><div class="input-group date">
                            <input type="text" name="product_discount[{{ discount_row }}][date_start]"
                                   value="{{ product_discount.date_start }}" placeholder="{{ entry_date_start }}"
                                   data-date-format="YYYY-MM-DD" class="form-control row{{ discount_row }}"/>
                            <span class="input-group-btn">
                          <button class="btn btn-default" type="button"><i class="fa fa-calendar"></i></button>
                          </span></div>
                        </td>
                      </tr>
                      <tr>
                        <td>
                          <div class="input-group date">
                            <input type="text" name="product_discount[{{ discount_row }}][date_end]"
                                   value="{{ product_discount.date_end }}" placeholder="{{ entry_date_end }}"
                                   data-date-format="YYYY-MM-DD" class="form-control row{{ discount_row }}"/>
                            <span class="input-group-btn">
                          <button class="btn btn-default" type="button"><i class="fa fa-calendar"></i></button>
                          </span></div>
                        </td>
                      </tr>
                    </table>

                  </td>

                  <td class="text-left">
                    <button type="button" onclick="$('#discount-row{{ discount_row }}').remove();" data-toggle="tooltip"
                            title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i>
                    </button>
                  </td>
                </tr>
                {% set discount_row =  discount_row + 1 %}
              {% endfor %}
              </tbody>
              <tfoot>
              <tr>
                <td colspan="8"></td>
                <td class="text-left">
                  <button type="button" onclick="addDiscount();" data-toggle="tooltip" title="{{ button_add }}"
                          class="btn btn-primary"><i class="fa fa-plus-circle"></i></button>
                </td>
              </tr>
              </tfoot>
            </table>
          </div>
        </form>
        <a class="btn btn-default" id="back-btn" href="{{ back_link }}"> < Back</a>
      </div>
    </div>
  </div>

  <script>
    $(document).ready(function () {
      init();
     });
  </script>


