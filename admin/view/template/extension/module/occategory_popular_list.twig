{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <a href="{{ add }}" data-toggle="tooltip" title="{{ button_insert }}" class="btn btn-primary"><i class="fa fa-plus"></i></a>
        <button type="button" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger" onclick="confirm('{{ text_confirm }}') ? $('#form-category-popular').submit() : false;"><i class="fa fa-trash-o"></i></button>
      </div>
      <h1>{{ heading_title }}</h1>
    </div>
  </div>
  <div class="container-fluid">
    <div class="row">
      <div class="col-md-12">
        <div class="panel panel-default">
          <div class="panel-heading">
            <h3 class="panel-title"><i class="fa fa-list"></i> {{ text_list }}</h3>
          </div>
          <div class="panel-body">
            <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-category-popular">
              <div class="table-responsive">
                <table class="table table-bordered table-hover">
                  <thead>
                    <tr>
                      <td style="width: 1px;" class="text-center"><input type="checkbox" onclick="$('input[name*=\'selected\']').prop('checked', this.checked);" /></td>
                      <td class="text-left">Name</td>
                      <td class="text-left">Status</td>
                      <td class="text-left">Sort</td>
                      <td class="text-right" style="width: 100px">Action</td>
                    </tr>
                  </thead>
                  <tbody>
                  
                  {% if categories %}
                  {% for category in categories %}
                    <tr>
                      <td class="text-center">{% if category.category_popular_id in selected %}
                        <input type="checkbox" name="selected[]" value="{{ category.category_popular_id }}" checked="checked" />
                        {% else %}
                        <input type="checkbox" name="selected[]" value="{{ category.category_popular_id }}" />
                        {% endif %}
                      </td>
                      <td class="text-left" style="width: 250px">{{ category.name }}</td>
                      <td class="text-left">{{ category.status }}</td>
                      <td class="text-left">{{ category.sort_order }}</td>
                      <td class="text-right" style="width: 100px">
                        <a href="{{ category.edit }}" data-toggle="tooltip" title="{{ text_edit }}" class="btn btn-primary"><i class="fa fa-pencil"></i></a>
                        <a href="{{ category.del }}" data-toggle="tooltip" title="{{ entry_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></a>
                      </td>
                    </tr>
                  {% endfor %}
                  {% else %}
                  <tr>
                    <td class="text-center" colspan="7">{{ text_no_results }}</td>
                  </tr>
                  {% endif %}
                    </tbody>
                </table>
              </div>
            </form>
            <div class="row">
              <div class="col-sm-6 text-left">{{ pagination }}</div>
              <div class="col-sm-6 text-right">{{ results }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

{{ footer }}
