{{ header }}{{ column_left }}
<div id="content">
    <div class="page-header">
        <div class="container-fluid">
            <div class="pull-right">
                <button type="submit" form="form-vchasno" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
                <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
            </div>
            <h1>{{ heading_title }}</h1>
            <ul class="breadcrumb">
                {% for breadcrumb in breadcrumbs %}
                    <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
                {% endfor %}
            </ul>
        </div>
    </div>
    <div class="container-fluid">
        {% if error_warning %}
            <div class="alert alert-danger"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        {% endif %}
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
            </div>
            <div class="panel-body">
                <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-vchasno" class="form-horizontal">
                    <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
                        <div class="col-sm-10">
                            <select name="module_vchasno_status" id="input-status" class="form-control">
                                {% if module_vchasno_status %}
                                    <option value="1" selected="selected">{{ text_enabled }}</option>
                                    <option value="0">{{ text_disabled }}</option>
                                {% else %}
                                    <option value="1">{{ text_enabled }}</option>
                                    <option value="0" selected="selected">{{ text_disabled }}</option>
                                {% endif %}
                            </select>
                        </div>
                    </div>

                    <h3>Загальні налаштування</h3>
                    <hr>
                    <div class="form-group required">
                        <label class="col-sm-2 control-label" for="input-token">{{ entry_token }}</label>
                        <div class="col-sm-10">
                            <input type="text" name="module_vchasno_token" value="{{ module_vchasno_token }}" placeholder="{{ entry_token }}" id="input-token" class="form-control" />
                            {% if error_token %}
                                <div class="text-danger">{{ error_token }}</div>
                            {% endif %}
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-cashier">{{ entry_cashier }}</label>
                        <div class="col-sm-10">
                            <input type="text" name="module_vchasno_cashier" value="{{ module_vchasno_cashier }}" placeholder="{{ entry_cashier }}" id="input-cashier" class="form-control" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-tax-group">{{ entry_tax_group }}</label>
                        <div class="col-sm-10">
                            <select name="module_vchasno_tax_group" id="input-tax-group" class="form-control">
                                <option value="1" {{ module_vchasno_tax_group == '1' ? 'selected' : '' }}>ПДВ (А)</option>
                                <option value="2" {{ module_vchasno_tax_group == '2' ? 'selected' : '' }}>ПДВ (Б)</option>
                                <option value="3" {{ module_vchasno_tax_group == '3' ? 'selected' : '' }}>Без ПДВ (Б)</option>
                                <option value="4" {{ module_vchasno_tax_group == '4' ? 'selected' : '' }}>Акциз (В)</option>
                            </select>
                        </div>
                    </div>

                    <h3>Правила автоматичного формування чеків</h3>
                    <hr>
                    <p class="text-muted">Налаштуйте для яких саме способів оплати створювати чеки автоматично. Ви завжди зможете створити чек вручну зі сторінки замовлення.</p>
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover">
                            <thead>
                                <tr>
                                    <td class="text-left">{{ entry_payment_method }}</td>
                                    <td class="text-left">{{ entry_payment_form }}</td>
                                </tr>
                            </thead>
                            <tbody>
                                {% for payment in payment_methods %}
                                    <tr>
                                        <td class="text-left">
                                            <div class="checkbox">
                                                <label>
                                                    <input type="checkbox" name="module_vchasno_rules[{{ payment.code }}][status]" value="1" {{ module_vchasno_rules[payment.code].status ? 'checked' : '' }} /> {{ payment.name }}
                                                </label>
                                            </div>
                                        </td>
                                        <td class="text-left">
                                            <select name="module_vchasno_rules[{{ payment.code }}][form]" class="form-control">
                                                <option value="Готівка" {{ module_vchasno_rules[payment.code].form == 'Готівка' ? 'selected' : '' }}>Готівка</option>
                                                <option value="Безготівка" {{ module_vchasno_rules[payment.code].form == 'Безготівка' ? 'selected' : '' }}>Безготівка</option>
                                                <option value="Картка" {{ module_vchasno_rules[payment.code].form == 'Картка' ? 'selected' : '' }}>Картка</option>
                                            </select>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    <h3>Додаткові налаштування</h3>
                    <hr>
                    <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-send-phone">{{ entry_send_phone }}</label>
                        <div class="col-sm-10">
                            <div class="checkbox">
                                <label>
                                    <input type="checkbox" name="module_vchasno_send_phone" value="1" {{ module_vchasno_send_phone ? 'checked' : '' }} id="input-send-phone" />
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-send-receipt">{{ entry_send_receipt }}</label>
                        <div class="col-sm-10">
                            <div class="checkbox">
                                <label>
                                    <input type="checkbox" name="module_vchasno_send_receipt" value="1" {{ module_vchasno_send_receipt ? 'checked' : '' }} id="input-send-receipt" />
                                </label>
                            </div>
                            <div class="input-group" style="margin-top: 10px;">
                                <input type="text" name="module_vchasno_send_type" value="{{ module_vchasno_send_type }}" placeholder="{{ entry_send_type }}" class="form-control" />
                                <span class="input-group-addon">{{ entry_send_type }}</span>
                            </div>
                            <p class="help-block">{{ help_send_type }}</p>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{{ footer }}
